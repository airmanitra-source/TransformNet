@page "/economie"
@rendermode InteractiveServer
@using MachineLearning.Web.Models.Agents.Companies
@using Simulation.Module
@using Simulation.Module.Models
@using Simulation.Module.Config
@using Company.Module.Models
@using MachineLearning.Web.Components.Parameters
@inject ISimulationModule Simulator
@implements IDisposable
@using MachineLearning.Web.Components.Results

<PageTitle>Simulateur Économique - Madagascar</PageTitle>

<h1> Simulateur Économique - Madagascar</h1>
<p class="text-muted">Simulation macroéconomique avec 3 agents : État, Ménages, Entreprises. <strong>1 seconde = 1 jour.</strong></p>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <strong>📋 Configuration du scénario</strong>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Scénario prédéfini</label>
                    <select class="form-select" @onchange="OnScenarioChange" disabled="@Simulator.EnCours">
                        @foreach (var s in _scenarios)
                        {
                            <option value="@s.Name">@s.Name</option>
                        }
                    </select>
                </div>

                @* ── Encadré bleu : récapitulatif du scénario ── *@
                @{
                    var impl = _config.Implications;
                    var borderColor = impl.Categorie switch
                    {
                        "social"     => "#198754",
                        "monetaire"  => "#0dcaf0",
                        "fiscal"     => "#fd7e14",
                        "budgetaire" => "#6f42c1",
                        "sectoriel"  => "#20c997",
                        "choc"       => "#dc3545",
                        "composite"  => "#6610f2",
                        _            => "#0d6efd"
                    };
                    var bgColor = impl.Categorie switch
                    {
                        "choc"  => "#fff5f5",
                        "social" => "#f0fff4",
                        _       => "#f0f6ff"
                    };
                }
                <div class="scenario-card mb-3" style="border-left: 4px solid @borderColor; background: @bgColor; border-radius: 0 0.4rem 0.4rem 0; padding: 0.85rem 1rem;">
                    <div class="scenario-card-title" style="font-weight:700; font-size:0.82rem; color:@borderColor; text-transform:uppercase; letter-spacing:.04em; margin-bottom:0.45rem;">
                        📋 @_config.Name
                    </div>
                    <div class="scenario-card-desc" style="font-size:0.82rem; color:#495057; margin-bottom:0.6rem;">
                        @_config.Description
                    </div>
                    @if (!impl.EstVide)
                    {
                        <div class="row g-1 small">
                            @if (impl.ChangementsClés.Length > 0)
                            {
                                <div class="col-12">
                                    <div style="font-weight:600; font-size:0.75rem; color:#6c757d; margin-bottom:0.2rem;">⚙️ CHANGEMENTS</div>
                                    @foreach (var c in impl.ChangementsClés)
                                    {
                                        <span class="badge me-1 mb-1" style="background:@borderColor; font-weight:500; font-size:0.72rem;">@c</span>
                                    }
                                </div>
                            }
                            @if (impl.CanauxTransmission.Length > 0)
                            {
                                <div class="col-12 mt-1">
                                    <div style="font-weight:600; font-size:0.75rem; color:#6c757d; margin-bottom:0.2rem;">🔗 CANAUX</div>
                                    @foreach (var t in impl.CanauxTransmission)
                                    {
                                        <div style="font-size:0.78rem; color:#212529;">• @t</div>
                                    }
                                </div>
                            }
                            @if (impl.RisquesAttendus.Length > 0)
                            {
                                <div class="col-12 mt-1">
                                    <div style="font-weight:600; font-size:0.75rem; color:#6c757d; margin-bottom:0.2rem;">⚠️ RISQUES</div>
                                    @foreach (var r in impl.RisquesAttendus)
                                    {
                                        <div style="font-size:0.78rem; color:#842029;">• @r</div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="mt-2" style="font-size:0.75rem; color:#6c757d;">
                            🕐 Horizon recommandé : <strong>@impl.HorizonRecommande</strong>
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Horizon temporel</label>
                    <div class="btn-group w-100" role="group">
                        <button class="btn @(_config.DureeJours == 90 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SetDuree(90)" disabled="@Simulator.EnCours">
                            3 mois
                        </button>
                        <button class="btn @(_config.DureeJours == 365 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SetDuree(365)" disabled="@Simulator.EnCours">
                            1 an
                        </button>
                        <button class="btn @(_config.DureeJours == 1825 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SetDuree(1825)" disabled="@Simulator.EnCours">
                            5 ans
                        </button>
                    </div>
                </div>

                <hr />

                <RecalibrationParameters Config="_config" Disabled="@Simulator.EnCours"
                    DerniereCollecte="_derniereCollecte"
                    OnCollecterDonnees="CollecterDonneesMacro"
                    OnAppliquerDonnees="AppliquerDonneesMacro"
                    DerniereCollecteInstat="_derniereCollecteInstat"
                    OnCollecterInstat="CollecterInstat"
                    OnAppliquerInstat="AppliquerInstat" />
                <CycloneParameters Config="_config" Disabled="@Simulator.EnCours" />
                <HouseholdParameters Config="_config" Disabled="@Simulator.EnCours" OnApplyPropension="ApplyPropensionToMenages" />
                <EnterpriseParameters Config="_config" Disabled="@Simulator.EnCours" />
                <TradeParameters Config="_config" Disabled="@Simulator.EnCours" />
                <GovernmentParameters Config="_config" Disabled="@Simulator.EnCours" />
                <BankingParameters Config="_config" Disabled="@Simulator.EnCours" />
                <div class="hr-placeholder"></div>
                <TransportParameters Config="_config" Disabled="@Simulator.EnCours" />
                <RiceConsumptionParameters Config="_config" Disabled="@Simulator.EnCours" />
                <JiramaParameters Config="_config" Disabled="@Simulator.EnCours" />
                <PriceElasticityParameters Config="_config" Disabled="@Simulator.EnCours" />
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <!-- Contrôles de simulation -->
        <div class="card mb-3">
            <div class="card-body d-flex align-items-center gap-3">
                @if (!Simulator.EnCours)
                {
                    <button class="btn btn-success btn-lg" @onclick="DemarrerTempsReel">
                        ▶️ Temps réel (1s = 1 jour)
                    </button>
                    <button class="btn btn-warning btn-lg" @onclick="DemarrerRapide">
                        ⏩ Simulation rapide
                    </button>
                }
                else
                {
                    <button class="btn btn-danger btn-lg" @onclick="Arreter">
                        ⏹️ Arrêter
                    </button>
                }

                <div class="flex-grow-1">
                    <div class="progress" style="height: 25px;">
                        <div class="progress-bar @(Simulator.Result.EstTerminee ? "bg-success" : "bg-info progress-bar-striped progress-bar-animated")"
                             style="width: @Progression()%">
                            Jour @Simulator.JourCourant / @_config.DureeJours (@FormatTemps(Simulator.JourCourant))
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <LiveSimulationResults Simulator="Simulator" Config="_config" />
    </div>
</div>
