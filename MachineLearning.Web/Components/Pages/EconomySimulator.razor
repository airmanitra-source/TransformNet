@page "/economie"
@rendermode InteractiveServer
@using MachineLearning.Web.Models.Agents.Companies
@using Simulation.Module
@using Simulation.Module.Models
@using Simulation.Module.Config
@using Company.Module.Models
@inject ISimulationModule Simulator
@implements IDisposable

<PageTitle>Simulateur Économique - Madagascar</PageTitle>

<h1> Simulateur Économique - Madagascar</h1>
<p class="text-muted">Simulation macroéconomique avec 3 agents : État, Ménages, Entreprises. <strong>1 seconde = 1 jour.</strong></p>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <strong>📋 Configuration du scénario</strong>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Scénario prédéfini</label>
                    <select class="form-select" @onchange="OnScenarioChange" disabled="@Simulator.EnCours">
                        @foreach (var s in _scenarios)
                        {
                            <option value="@s.Name">@s.Name</option>
                        }
                    </select>
                    <small class="text-muted">@_config.Description</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Horizon temporel</label>
                    <div class="btn-group w-100" role="group">
                        <button class="btn @(_config.DureeJours == 90 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SetDuree(90)" disabled="@Simulator.EnCours">
                            3 mois
                        </button>
                        <button class="btn @(_config.DureeJours == 365 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SetDuree(365)" disabled="@Simulator.EnCours">
                            1 an
                        </button>
                        <button class="btn @(_config.DureeJours == 1825 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SetDuree(1825)" disabled="@Simulator.EnCours">
                            5 ans
                        </button>
                </div>

                <h6>🏠 Ménages — Distribution salariale</h6>
                
                <div class="mb-2">
                    <label class="form-label">Nombre de ménages : <strong>@_config.NombreMenages.ToString("N0")</strong></label>
                    <input type="range" class="form-range" min="20" max="5000000" step="100"
                           @bind="_config.NombreMenages" @bind:event="oninput" disabled="@Simulator.EnCours" />
                    <small class="text-muted">20–5 000 000 ménages</small>
                </div>
                <div class="mb-2">
                    <label class="form-label">Salaire médian : <strong>@FormatMGA(_config.SalaireMedian)</strong></label>
                    <input type="range" class="form-range" min="80000" max="500000" step="5000"
                           @bind="_config.SalaireMedian" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <details class="mb-2">
                    <summary class="fw-bold" style="cursor: pointer;">📊 Propension marginale à consommer par classe</summary>
                    <div class="mt-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="text-muted d-block mb-2">Valeurs appliquées à l'initialisation des ménages selon leur classe socio‑économique.</small>
                            <button class="btn btn-sm btn-outline-primary" @onclick="ApplyPropensionToMenages">Appliquer aux ménages</button>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Subsistance : <strong>@(_config.PropensionConsommation_Subsistance.ToString("P0"))</strong></label>
                            <input type="range" class="form-range" min="0.10" max="0.99" step="0.01"
                                   value="@_config.PropensionConsommation_Subsistance"
                                   @oninput="OnPropensionSubsistanceInput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Informel bas : <strong>@(_config.PropensionConsommation_InformelBas.ToString("P0"))</strong></label>
                            <input type="range" class="form-range" min="0.10" max="0.99" step="0.01"
                                   value="@_config.PropensionConsommation_InformelBas"
                                   @oninput="OnPropensionInformelBasInput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Formel bas : <strong>@(_config.PropensionConsommation_FormelBas.ToString("P0"))</strong></label>
                            <input type="range" class="form-range" min="0.10" max="0.99" step="0.01"
                                   value="@_config.PropensionConsommation_FormelBas"
                                   @oninput="OnPropensionFormelBasInput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Formel qualifié : <strong>@(_config.PropensionConsommation_FormelQualifie.ToString("P0"))</strong></label>
                            <input type="range" class="form-range" min="0.10" max="0.99" step="0.01"
                                   value="@_config.PropensionConsommation_FormelQualifie"
                                   @oninput="OnPropensionFormelQualifieInput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Cadre : <strong>@(_config.PropensionConsommation_Cadre.ToString("P0"))</strong></label>
                            <input type="range" class="form-range" min="0.10" max="0.99" step="0.01"
                                   value="@_config.PropensionConsommation_Cadre"
                                   @oninput="OnPropensionCadreInput" disabled="@Simulator.EnCours" />
                        </div>
                    </div>
                </details>
                <div class="mb-2">
                    <label class="form-label">Inégalités (σ) : <strong>@_config.SalaireSigma.ToString("F2")</strong>
                        → Gini ≈ @GiniEstime().ToString("F2")</label>
                    <input type="range" class="form-range" min="0.30" max="1.50" step="0.05"
                           @bind="_config.SalaireSigma" @bind:event="oninput" disabled="@Simulator.EnCours" />
                    <div class="d-flex justify-content-between">
                        <small class="text-success">Égalitaire</small>
                        <small class="text-danger">Très inégal</small>
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label">Salaire plancher : <strong>@FormatMGA(_config.SalairePlancher)</strong></label>
                    <input type="range" class="form-range" min="20000" max="200000" step="5000"
                           @bind="_config.SalairePlancher" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>

                <details class="mb-2">
                    <summary class="fw-bold" style="cursor: pointer;">🎓 Éducation des ménages</summary>
                    <div class="mt-2">
                        <div class="mb-2">
                            <label class="form-label">Nombre moyen d'enfants/ménage : <strong>@_config.NombreEnfantsMoyenParMenage.ToString("F1")</strong></label>
                            <input type="range" class="form-range" min="0" max="6" step="0.1"
                                   @bind="_config.NombreEnfantsMoyenParMenage" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Part des enfants scolarisés : <strong>@((_config.PartEnfantsScolarises * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.20" max="1.00" step="0.01"
                                   @bind="_config.PartEnfantsScolarises" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Durée annuelle des dépenses d'éducation : <strong>@FormatTemps(_config.DureeDepenseEducationJours)</strong></label>
                            <input type="range" class="form-range" min="30" max="300" step="5"
                                   @bind="_config.DureeDepenseEducationJours" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Coût journalier par enfant : <strong>@FormatMGA(_config.CoutEducationJournalierParEnfant)</strong></label>
                            <input type="range" class="form-range" min="100" max="5000" step="50"
                                   @bind="_config.CoutEducationJournalierParEnfant" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Part formelle de la dépense d'éducation : <strong>@((_config.PartFormelleDepenseEducation * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.20" max="1.00" step="0.01"
                                   @bind="_config.PartFormelleDepenseEducation" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="p-2 border rounded bg-light">
                            <small class="fw-bold">📚 Résumé éducation :</small>
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                <span class="badge bg-primary">Enfants: @_config.NombreEnfantsMoyenParMenage.ToString("F1")/ménage</span>
                                <span class="badge bg-success">Scolarisation: @((_config.PartEnfantsScolarises * 100).ToString("F0"))%</span>
                                <span class="badge bg-info text-dark">Coût/enfant: @FormatMGA(_config.CoutEducationJournalierParEnfant)</span>
                            </div>
                        </div>
                    </div>
                </details>

                <details class="mb-2">
                    <summary class="fw-bold" style="cursor: pointer;">🏥 Santé des ménages</summary>
                    <div class="mt-2">
                        <div class="mb-2">
                            <label class="form-label">Taux d'occupation des hôpitaux : <strong>@((_config.TauxOccupationHopitaux * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.10" max="1.00" step="0.01"
                                   @bind="_config.TauxOccupationHopitaux" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Coût consultation de base : <strong>@FormatMGA(_config.CoutConsultationSanteBase)</strong></label>
                            <input type="range" class="form-range" min="1000" max="50000" step="500"
                                   @bind="_config.CoutConsultationSanteBase" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Coût hospitalisation de base : <strong>@FormatMGA(_config.CoutHospitalisationSanteBase)</strong></label>
                            <input type="range" class="form-range" min="5000" max="150000" step="1000"
                                   @bind="_config.CoutHospitalisationSanteBase" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Part formelle de la dépense de santé : <strong>@((_config.PartFormelleDepenseSante * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.20" max="1.00" step="0.01"
                                   @bind="_config.PartFormelleDepenseSante" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="p-2 border rounded bg-light">
                            <small class="fw-bold">🩺 Résumé santé :</small>
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                <span class="badge bg-danger">Occupation: @((_config.TauxOccupationHopitaux * 100).ToString("F0"))%</span>
                                <span class="badge bg-warning text-dark">Consultation: @FormatMGA(_config.CoutConsultationSanteBase)</span>
                                <span class="badge bg-secondary">Hospitalisation: @FormatMGA(_config.CoutHospitalisationSanteBase)</span>
                            </div>
                        </div>
                    </div>
                </details>

                <details class="mb-2">
                    <summary class="fw-bold" style="cursor: pointer;">🏘️ Logement, loyers et auto-construction</summary>
                    <div class="mt-2">
                        <div class="mb-2">
                            <label class="form-label">Taux de propriétaires : <strong>@((_config.TauxMenagesProprietaires * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.10" max="0.95" step="0.01"
                                   @bind="_config.TauxMenagesProprietaires" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Loyer journalier locataire : <strong>@FormatMGA(_config.LoyerJourLocataire)</strong></label>
                            <input type="range" class="form-range" min="500" max="20000" step="100"
                                   @bind="_config.LoyerJourLocataire" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Probabilité de construction chez les locataires : <strong>@((_config.ProbabiliteConstructionMaisonLocataire * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.00" max="0.40" step="0.01"
                                   @bind="_config.ProbabiliteConstructionMaisonLocataire" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Durée de construction : <strong>@FormatTemps(_config.DureeConstructionMaisonJours)</strong></label>
                            <input type="range" class="form-range" min="30" max="720" step="10"
                                   @bind="_config.DureeConstructionMaisonJours" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Budget journalier de construction : <strong>@FormatMGA(_config.BudgetConstructionMaisonJour)</strong></label>
                            <input type="range" class="form-range" min="500" max="30000" step="100"
                                   @bind="_config.BudgetConstructionMaisonJour" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Part BTP : <strong>@((_config.PartBudgetConstructionBTP * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.10" max="0.80" step="0.01"
                                   @bind="_config.PartBudgetConstructionBTP" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Part quincaillerie : <strong>@((_config.PartBudgetConstructionQuincaillerie * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.05" max="0.70" step="0.01"
                                   @bind="_config.PartBudgetConstructionQuincaillerie" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Part transport informel briques/matériaux : <strong>@((_config.PartBudgetConstructionTransportInformel * 100).ToString("F0"))%</strong></label>
                            <input type="range" class="form-range" min="0.00" max="0.50" step="0.01"
                                   @bind="_config.PartBudgetConstructionTransportInformel" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        </div>
                        <div class="p-2 border rounded bg-light">
                            <small class="fw-bold">🏗️ Résumé logement :</small>
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                <span class="badge bg-secondary">Locataires: @(((1 - _config.TauxMenagesProprietaires) * 100).ToString("F0"))%</span>
                                <span class="badge bg-primary">Loyer: @FormatMGA(_config.LoyerJourLocataire)/jour</span>
                                <span class="badge bg-success">Construction: @FormatMGA(_config.BudgetConstructionMaisonJour)/jour</span>
                            </div>
                            <small class="text-muted d-block mt-1">Les parts BTP/quincaillerie/transport sont normalisées côté simulation avant routage.</small>
                        </div>
                    </div>
                </details>

                <HouseholdParameters Config="_config" Disabled="@Simulator.EnCours" OnApplyPropension="ApplyPropensionToMenages" />
                <EnterpriseParameters Config="_config" Disabled="@Simulator.EnCours" />

                <TradeParameters Config="_config" Disabled="@Simulator.EnCours" />

                <GovernmentParameters Config="_config" Disabled="@Simulator.EnCours" />
                <BankingParameters Config="_config" Disabled="@Simulator.EnCours" />
                <div class="hr-placeholder"></div>
                </div>

                <hr />
                <h6>⛽ Transport & carburant</h6>
                <div class="mb-2">
                    <label class="form-label">Prix carburant : <strong>@FormatMGA(_config.PrixCarburantLitre)/L</strong></label>
                    <input type="range" class="form-range" min="3000" max="15000" step="100"
                           @bind="_config.PrixCarburantLitre" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <div class="p-2 border rounded bg-light">
                    <small class="fw-bold">🚌 Coûts transport/jour :</small>
                    <div class="d-flex flex-wrap gap-1 mt-1">
                        <span class="badge bg-secondary">🚌 Public: 1 200 MGA</span>
                        <span class="badge bg-secondary">🏍️ Moto: ~@FormatMGA(_config.PrixCarburantLitre * 0.6)</span>
                        <span class="badge bg-secondary">🚗 Voiture: ~@FormatMGA(_config.PrixCarburantLitre * 1.6 + 500)</span>
                    </div>
                </div>

                <hr />
                <h6>🍚 Consommation de riz</h6>
                <div class="mb-2">
                    <label class="form-label">Conso. annuelle/pers : <strong>@_config.ConsommationRizAnnuelleKgParPersonne.ToString("F0") kg</strong></label>
                    <input type="range" class="form-range" min="50" max="200" step="5"
                           @bind="_config.ConsommationRizAnnuelleKgParPersonne" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Prix riz local : <strong>@FormatMGA(_config.PrixRizLocalKg)/kg</strong></label>
                    <input type="range" class="form-range" min="1000" max="5000" step="100"
                           @bind="_config.PrixRizLocalKg" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Prix riz importé : <strong>@FormatMGA(_config.PrixRizImporteKg)/kg</strong></label>
                    <input type="range" class="form-range" min="1500" max="6000" step="100"
                           @bind="_config.PrixRizImporteKg" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Part riz importé : <strong>@((_config.PartRizImporte * 100).ToString("F0"))%</strong></label>
                    <input type="range" class="form-range" min="0.05" max="0.50" step="0.01"
                           @bind="_config.PartRizImporte" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <div class="p-2 border rounded bg-light">
                    <small class="fw-bold">🍚 Coût riz estimé/ménage/jour :</small>
                    <span class="badge bg-secondary">
                        ~@FormatMGA((_config.ConsommationRizAnnuelleKgParPersonne / 365.0) * 4.5 * (_config.PrixRizLocalKg * (1.0 - _config.PartRizImporte) + _config.PrixRizImporteKg * _config.PartRizImporte))
                    </span>
                </div>

                <hr />
                <h6>💧⚡ JIRAMA (eau & électricité)</h6>
                <div class="mb-2">
                    <label class="form-label">Tarif eau/jour/ménage : <strong>@FormatMGA(_config.TarifEauJourMenage)</strong></label>
                    <input type="range" class="form-range" min="100" max="2000" step="50"
                           @bind="_config.TarifEauJourMenage" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Prix élec. : <strong>@_config.PrixElectriciteArKWh.ToString("F0") Ar/KWh</strong></label>
                    <input type="range" class="form-range" min="400" max="1200" step="10"
                           @bind="_config.PrixElectriciteArKWh" @bind:event="oninput" disabled="@Simulator.EnCours" />
                    <small class="text-muted">Source Tableau 21 : 610→653 Ar/KWh (2023-2025)</small>
                </div>
                <div class="mb-2">
                    <label class="form-label">Conso. élec./ménage/jour : <strong>@_config.ConsommationElecMenageKWhJour.ToString("F2") KWh</strong></label>
                    <input type="range" class="form-range" min="0.30" max="3.00" step="0.05"
                           @bind="_config.ConsommationElecMenageKWhJour" @bind:event="oninput" disabled="@Simulator.EnCours" />
                    <small class="text-muted">~30,8 KWh/mois = 1,03 KWh/jour (moy. nationale)</small>
                </div>
                <div class="mb-2">
                    <label class="form-label">Taux accès eau : <strong>@((_config.TauxAccesEau * 100).ToString("F0"))%</strong></label>
                    <input type="range" class="form-range" min="0.05" max="0.80" step="0.01"
                           @bind="_config.TauxAccesEau" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Taux accès électricité : <strong>@((_config.TauxAccesElectricite * 100).ToString("F0"))%</strong></label>
                    <input type="range" class="form-range" min="0.05" max="0.80" step="0.01"
                           @bind="_config.TauxAccesElectricite" @bind:event="oninput" disabled="@Simulator.EnCours" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Pertes réseau : <strong>@((_config.TauxPertesDistribution * 100).ToString("F1"))%</strong></label>
                    <input type="range" class="form-range" min="0.05" max="0.50" step="0.01"
                           @bind="_config.TauxPertesDistribution" @bind:event="oninput" disabled="@Simulator.EnCours" />
                    <small class="text-muted">Norme internat. 8-12%, JIRAMA ~28,9%</small>
                </div>
                <div class="p-2 border rounded bg-light">
                    <small class="fw-bold">💡 JIRAMA — Factures mensuelles estimées :</small>
                    <div class="d-flex flex-wrap gap-1 mt-1">
                        <span class="badge bg-info text-dark">💧 Eau: ~@FormatMGA(_config.TarifEauJourMenage * 30)/mois</span>
                        <span class="badge bg-warning text-dark">⚡ Élec: ~@FormatMGA(_config.ConsommationElecMenageKWhJour * _config.PrixElectriciteArKWh * 30)/mois</span>
                    </div>
                    <div class="mt-1">
                        <small class="text-muted">🔋 Part hydraulique : @((_config.PartProductionHydraulique * 100).ToString("F0"))% | Thermique : @(((1 - _config.PartProductionHydraulique) * 100).ToString("F0"))%</small>
                    </div>
                </div>

                <hr />
                <h6>📈 Élasticité & Prix — Configuration avancée</h6>
                <p class="small text-muted">Paramètres de transmission carburant → prix. <a href="/doc-prix" target="_blank">📖 Doc</a></p>

                <div class="mb-2">
                    <label class="form-label">Élasticité prix/carburant : <strong>@_config.ElasticitePrixParCarburant.ToString("F2")</strong></label>
                    <input type="range" class="form-range" min="0.30" max="1.00" step="0.05"
                           @bind="_config.ElasticitePrixParCarburant" @bind:event="oninput" />
                    <small class="text-muted">0.30=absorption | 0.70=modérée | 1.0=complète</small>
                </div>

                <div class="mb-2">
                    <label class="form-label">Volatilité marché : <strong>±@((_config.VolatiliteAleatoireMarche * 100).ToString("F0"))%</strong></label>
                    <input type="range" class="form-range" min="0.05" max="0.20" step="0.01"
                           @bind="_config.VolatiliteAleatoireMarche" @bind:event="oninput" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Part revenu alimentaire : <strong>@((_config.PartRevenuAlimentaire * 100).ToString("F0"))%</strong></label>
                    <input type="range" class="form-range" min="0.20" max="0.60" step="0.02"
                           @bind="_config.PartRevenuAlimentaire" @bind:event="oninput" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Élasticité comportement ménage : <strong>@_config.ElasticiteComportementMenage.ToString("F2")</strong></label>
                    <input type="range" class="form-range" min="0.30" max="1.00" step="0.05"
                           @bind="_config.ElasticiteComportementMenage" @bind:event="oninput" />
                </div>

                <hr />
                <h6>🔄 Recalibration mensuelle</h6>
                <p class="small text-muted">
                    Ancrage sur données macro observées (BCM, INSTAT, DGI).
                    À chaque fin de mois, la simulation ajuste ses paramètres pour converger vers la réalité.
                </p>

                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="recalibSwitch"
                           @bind="_config.RecalibrationMensuelleActivee" disabled="@Simulator.EnCours" />
                    <label class="form-check-label" for="recalibSwitch">
                        Activer la recalibration mensuelle
                    </label>
                </div>

                @if (_config.RecalibrationMensuelleActivee)
                {
                    <div class="mb-2">
                        <label class="form-label">Vitesse de convergence : <strong>@((_config.VitesseConvergenceRecalibration * 100).ToString("F0"))%</strong></label>
                        <input type="range" class="form-range" min="0.1" max="1.0" step="0.1"
                               @bind="_config.VitesseConvergenceRecalibration" @bind:event="oninput" disabled="@Simulator.EnCours" />
                        <div class="d-flex justify-content-between">
                            <small class="text-success">Douce (10%)</small>
                            <small class="text-danger">Totale (100%)</small>
                        </div>
                    </div>

                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong class="small">Cibles mensuelles</strong>
                            <button class="btn btn-sm btn-outline-primary" @onclick="AjouterCibleMensuelle"
                                    disabled="@Simulator.EnCours">+ Ajouter mois</button>
                        </div>

                        @if (_config.CiblesMensuelles.Count == 0)
                        {
                            <div class="alert alert-secondary py-1 small">
                                Aucune cible définie. Cliquez "Ajouter mois" pour entrer les données macro observées.
                            </div>
                        }
                        else
                        {
                            <div style="max-height: 300px; overflow-y: auto;">
                                @foreach (var cible in _config.CiblesMensuelles.OrderBy(c => c.Mois))
                                {
                                    <div class="card mb-1">
                                        <div class="card-body p-2">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <strong class="small">📅 Mois @cible.Mois @(!string.IsNullOrEmpty(cible.Label) ? $"({cible.Label})" : "")</strong>
                                                <button class="btn btn-sm btn-outline-danger py-0 px-1"
                                                        @onclick="() => SupprimerCibleMensuelle(cible.Mois)"
                                                        disabled="@Simulator.EnCours">✕</button>
                                            </div>
                                            <div class="row g-1">
                                                <div class="col-6">
                                                    <label class="form-label mb-0 small">🏦 M3 (Mds MGA)</label>
                                                    <input type="number" class="form-control form-control-sm"
                                                           value="@(cible.M3Cible.HasValue ? (cible.M3Cible.Value / 1_000_000_000).ToString("F0") : "")"
                                                           @onchange="(e) => SetCibleM3(cible, e)"
                                                           disabled="@Simulator.EnCours" placeholder="ex: 30000" />
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label mb-0 small">💰 Recettes fisc. (Mds)</label>
                                                    <input type="number" class="form-control form-control-sm"
                                                           value="@(cible.RecettesFiscalesCumuleesCible.HasValue ? (cible.RecettesFiscalesCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                                           @onchange="(e) => SetCibleFiscale(cible, e)"
                                                           disabled="@Simulator.EnCours" placeholder="ex: 1500" />
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label mb-0 small">📦 Exports FOB (Mds)</label>
                                                    <input type="number" class="form-control form-control-sm"
                                                           value="@(cible.ExportationsFOBCumuleesCible.HasValue ? (cible.ExportationsFOBCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                                           @onchange="(e) => SetCibleExports(cible, e)"
                                                           disabled="@Simulator.EnCours" placeholder="ex: 1100" />
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label mb-0 small">🚢 Imports CIF (Mds)</label>
                                                    <input type="number" class="form-control form-control-sm"
                                                           value="@(cible.ImportationsCIFCumuleesCible.HasValue ? (cible.ImportationsCIFCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                                           @onchange="(e) => SetCibleImports(cible, e)"
                                                           disabled="@Simulator.EnCours" placeholder="ex: 1500" />
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label mb-0 small">🏨 Devises tourisme (Mds)</label>
                                                    <input type="number" class="form-control form-control-sm"
                                                           value="@(cible.DevisesTourismeCible.HasValue ? (cible.DevisesTourismeCible.Value / 1_000_000_000).ToString("F1") : "")"
                                                           @onchange="(e) => SetCibleTourisme(cible, e)"
                                                           disabled="@Simulator.EnCours" placeholder="ex: 50" />
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label mb-0 small">👷 Nv. affiliés CNaPS</label>
                                                    <input type="number" class="form-control form-control-sm"
                                                           value="@(cible.NouveauxAffiliesCNaPSCible?.ToString() ?? "")"
                                                           @onchange="(e) => SetCibleCNaPS(cible, e)"
                                                           disabled="@Simulator.EnCours" placeholder="ex: 5000" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <!-- Contrôles de simulation -->
        <div class="card mb-3">
            <div class="card-body d-flex align-items-center gap-3">
                @if (!Simulator.EnCours)
                {
                    <button class="btn btn-success btn-lg" @onclick="DemarrerTempsReel">
                        ▶️ Temps réel (1s = 1 jour)
                    </button>
                    <button class="btn btn-warning btn-lg" @onclick="DemarrerRapide">
                        ⏩ Simulation rapide
                    </button>
                }
                else
                {
                    <button class="btn btn-danger btn-lg" @onclick="Arreter">
                        ⏹️ Arrêter
                    </button>
                }

                <div class="flex-grow-1">
                    <div class="progress" style="height: 25px;">
                        <div class="progress-bar @(Simulator.Result.EstTerminee ? "bg-success" : "bg-info progress-bar-striped progress-bar-animated")"
                             style="width: @Progression()%">
                            Jour @Simulator.JourCourant / @_config.DureeJours (@FormatTemps(Simulator.JourCourant))
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KPIs -->
        @if (Simulator.Result.Snapshots.Count > 0)
        {
            var last = Simulator.Result.Snapshots[^1];
            <div class="row mb-3">
                <div class="col-md-3">
                    <div class="card text-center border-info kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">💰 Épargne ménages</h6>
                            <h4 class="text-info">@FormatMGA(last.EpargneTotaleMenages)</h4>
                            <small>Moy: @FormatMGA(last.EpargneMoyenneMenages)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-success kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">🏛️ Recettes fiscales</h6>
                            <h4 class="text-success">@FormatMGA(last.RecettesFiscalesTotales)</h4>
                            <small>IR: @FormatMGA(last.RecettesIR)/j</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-warning kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">📊 PIB par revenus</h6>
                            <h4 class="text-warning">@FormatMGA(last.PIBParRevenus)</h4>
                            <small>Salaires + Profits + Impôts</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-danger kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">📉 Dette publique</h6>
                            <h4 class="text-danger">@FormatMGA(last.DettePublique)</h4>
                            <small>Solde: @FormatMGA(last.SoldeBudgetaire)</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Secteur Bancaire et M3 -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="card text-center border-primary kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">🏦 Masse Monétaire M3</h6>
                            <h4 class="text-primary">@FormatMGA(last.MasseMonetaireM3)</h4>
                            <small>Base crédit monétaire de la simulation</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-info kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">💼 Dépôts Bancaires</h6>
                            <h4 class="text-info">@FormatMGA(last.TotalDepotsBancaires)</h4>
                            <small>Ménages + Entreprises</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-success kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">💳 Crédits Accordés (cumul)</h6>
                            <h4 class="text-success">@FormatMGA(last.TotalCreditsAccordes)</h4>
                            <small>Nouvelle monnaie créée</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3 estimations du PIB pour validation croisée -->
            <div class="row mb-3">
                <div class="col-md-12">
                    <div class="card border-warning">
                        <div class="card-header bg-warning text-dark">
                            <strong>📊 PIB - Validation croisée des 3 méthodes de calcul</strong>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-md-4">
                                    <div class="p-3 border rounded bg-light">
                                        <small class="text-muted">1️⃣ PIB par la demande</small><br />
                                        <strong class="fs-4 text-primary">@FormatMGA(last.PIBProxy)</strong>
                                        <br /><small class="text-muted">C + I(FBCF+ΔS) + G + (X - M)</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 border rounded bg-light">
                                        <small class="text-muted">2️⃣ PIB par la valeur ajoutée</small><br />
                                        <strong class="fs-4 text-success">@FormatMGA(last.PIBParValeurAjoutee)</strong>
                                        <br /><small class="text-muted">Σ(VA entreprises + JIRAMA + Admin + Loyers)</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 border rounded bg-light">
                                        <small class="text-muted">3️⃣ PIB par les revenus</small><br />
                                        <strong class="fs-4 text-warning">@FormatMGA(last.PIBParRevenus)</strong>
                                        <br /><small class="text-muted">Salaires + EBE + Impôts prod.</small>
                                    </div>
                                </div>
                            </div>
                            <hr class="my-2" />
                            <div class="text-center">
                                <small class="text-muted">
                                    💡 En théorie, les 3 méthodes devraient converger vers la même valeur.
                                    Écarts: 
                                    <strong>Demande ↔ VA: @CalculerEcart(last.PIBProxy, last.PIBParValeurAjoutee)%</strong> | 
                                    <strong>VA ↔ Revenus: @CalculerEcart(last.PIBParValeurAjoutee, last.PIBParRevenus)%</strong>
                                </small>
                            </div>
                            <hr class="my-2" />
                            <div class="row">
                                <div class="col-md-4">
                                    <small class="text-muted"><strong>Demande :</strong></small><br />
                                    <small>C ménages : @FormatMGA(last.ConsommationTotaleMenages)</small><br />
                                    <small>FBCF : @FormatMGA(last.FBCF)</small><br />
                                    <small>ΔStocks : @FormatMGA(last.VariationStocksImportateurs)</small><br />
                                    <small>G (conso. État) : @FormatMGA(last.DepensesPubliques - last.SubventionsJirama)</small><br />
                                    <small>X - M : @FormatMGA(last.BalanceCommerciale)</small><br />
                                    <small>Loyers imputés : @FormatMGA(last.LoyersImputesTotaux)</small>
                                </div>
                                <div class="col-md-4">
                                    <small class="text-muted"><strong>Valeur ajoutée :</strong></small><br />
                                    <small>VA entreprises : @FormatMGA(last.ChiffreAffairesTotalEntreprises - last.VentesB2BTotales)</small><br />
                                    <small>VA JIRAMA : @FormatMGA(last.ValeurAjouteeJirama)</small><br />
                                    <small>VA Admin publique : @FormatMGA(last.ValeurAjouteeAdminPublique)</small><br />
                                    <small>Loyers imputés : @FormatMGA(last.LoyersImputesTotaux)</small>
                                </div>
                                <div class="col-md-4">
                                    <small class="text-muted"><strong>Revenus :</strong></small><br />
                                    <small>Salaires entreprises : @FormatMGA(last.ChargesSalarialesTotalesEntreprises)</small><br />
                                    <small>CNaPS patronales : @FormatMGA(last.CotisationsCNaPSPatronalesTotales)</small><br />
                                    <small>Sal. fonctionnaires : @FormatMGA(last.SalairesFonctionnaires)</small><br />
                                    <small>EBE (profits) : @FormatMGA(last.ExcedentBrutExploitation)</small><br />
                                    <small>Impôts production : @FormatMGA(last.RecettesTVA + last.RecettesDouanieres)</small><br />
                                    <small>Loyers imputés : @FormatMGA(last.LoyersImputesTotaux)</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Commerce extérieur -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="card text-center border-primary kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">🚢 Imports CIF/j</h6>
                            <h4 class="text-primary">@FormatMGA(last.ImportationsCIF)</h4>
                            <small>@last.NbImportateurs importateurs</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-success kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">📦 Exports FOB/j</h6>
                            <h4 class="text-success">@FormatMGA(last.ExportationsFOB)</h4>
                            <small>@last.NbExportateurs exportateurs</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center kpi-card @(last.BalanceCommerciale >= 0 ? "border-success" : "border-danger")">
                        <div class="card-body">
                            <h6 class="card-title text-muted">⚖️ Balance commerciale</h6>
                            <h4 class="@(last.BalanceCommerciale >= 0 ? "text-success" : "text-danger")">@FormatMGA(last.BalanceCommerciale)</h4>
                            <small>Douanes: @FormatMGA(last.RecettesDouanieres)/j</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Riz & JIRAMA -->
            <div class="row mb-3">
                <div class="col-md-3">
                    <div class="card text-center border-warning kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">🍚 Dépenses riz/j</h6>
                            <h4 class="text-warning">@FormatMGA(last.DepensesRizTotales)</h4>
                            <small>Tous ménages confondus</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-info kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">💧⚡ JIRAMA recettes/j</h6>
                            <h4 class="text-info">@FormatMGA(last.RecettesTotalesJirama)</h4>
                            <small>Eau: @FormatMGA(last.RecettesEauJirama) | Élec: @FormatMGA(last.RecettesElectriciteJirama)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-secondary kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">⚡ Conso. élec. ménages</h6>
                            <h4 class="text-secondary">@last.ConsommationMenagesKWh.ToString("N0") KWh</h4>
                            <small>Prod. estimée: @last.ProductionElecKWh.ToString("N0") KWh</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-primary kpi-card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">🔌 Abonnés & facture</h6>
                            <h4 class="text-primary">@FormatMGA(last.FactureElecMoyenneParMenage)/j</h4>
                            <small>💧 @last.NbAbonnesEau.ToString("N0") | ⚡ @last.NbAbonnesElectricite.ToString("N0") abonnés</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Distribution salariale & inégalités -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="card border-purple">
                        <div class="card-header bg-dark text-white">
                            📊 Distribution salariale initiale (log-normale)
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col">
                                    <small class="text-muted">Médiane</small><br />
                                    <strong>@FormatMGA(Simulator.StatsInitiales.Mediane)</strong>
                                </div>
                                <div class="col">
                                    <small class="text-muted">Moyenne</small><br />
                                    <strong>@FormatMGA(Simulator.StatsInitiales.Moyenne)</strong>
                                </div>
                                <div class="col">
                                    <small class="text-muted">Gini initial</small><br />
                                    <strong>@Simulator.StatsInitiales.Gini.ToString("F3")</strong>
                                </div>
                                <div class="col">
                                    <small class="text-muted">D9/D1</small><br />
                                    <strong>@Simulator.StatsInitiales.RatioD9D1.ToString("F1")</strong>
                                </div>
                            </div>
                            <hr class="my-2" />
                            <small class="fw-bold">Quintiles (salaire mensuel) :</small>
                            <div class="d-flex justify-content-between mt-1">
                                <span class="badge bg-danger">Q1: @FormatMGA(Simulator.StatsInitiales.Q1Moyenne)</span>
                                <span class="badge bg-warning text-dark">Q2: @FormatMGA(Simulator.StatsInitiales.Q2Moyenne)</span>
                                <span class="badge bg-info">Q3: @FormatMGA(Simulator.StatsInitiales.Q3Moyenne)</span>
                                <span class="badge bg-primary">Q4: @FormatMGA(Simulator.StatsInitiales.Q4Moyenne)</span>
                                <span class="badge bg-success">Q5: @FormatMGA(Simulator.StatsInitiales.Q5Moyenne)</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-dark text-white">
                            📈 Inégalités en temps réel
                        </div>
                        <div class="card-body">
                            <div class="row text-center mb-2">
                                <div class="col">
                                    <small class="text-muted">Gini (épargne)</small><br />
                                    <h5 class="@(last.Gini > 0.5 ? "text-danger" : last.Gini > 0.4 ? "text-warning" : "text-success")">
                                        @last.Gini.ToString("F3")
                                    </h5>
                                </div>
                                <div class="col">
                                    <small class="text-muted">Ratio D9/D1</small><br />
                                    <h5>@last.RatioD9D1.ToString("F1")x</h5>
                                </div>
                            </div>
                            <small class="fw-bold">Épargne moy. par quintile :</small>
                            <div class="d-flex justify-content-between mt-1">
                                <span class="badge bg-danger">Q1: @FormatMGA(last.EpargneQ1)</span>
                                <span class="badge bg-warning text-dark">Q2: @FormatMGA(last.EpargneQ2)</span>
                                <span class="badge bg-info">Q3: @FormatMGA(last.EpargneQ3)</span>
                                <span class="badge bg-primary">Q4: @FormatMGA(last.EpargneQ4)</span>
                                <span class="badge bg-success">Q5: @FormatMGA(last.EpargneQ5)</span>
                            </div>
                            <hr class="my-2" />
                            <small class="fw-bold">Répartition des classes :</small>
                            <div class="d-flex justify-content-between mt-1">
                                <span class="badge bg-secondary">Subsist. @last.NbSubsistance</span>
                                <span class="badge bg-secondary">Inf.bas @last.NbInformelBas</span>
                                <span class="badge bg-secondary">Form.bas @last.NbFormelBas</span>
                                <span class="badge bg-secondary">Qualifié @last.NbFormelQualifie</span>
                                <span class="badge bg-secondary">Cadre @last.NbCadre</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Validation cohérence CA par secteur -->
            <div class="row mb-3">
                <div class="col-md-12">
                    <div class="card border-primary">
                        <div class="card-header bg-primary text-white">
                            ✅ Validation : Cohérence CA par employé et secteur
                        </div>
                        <div class="card-body">
                            <div class="row text-center mb-3">
                                <div class="col-md-3">
                                    <small class="text-muted">Entreprises assujetties TVA</small><br />
                                    <strong class="fs-5 text-success">@last.NbEntreprisesAssujettiesTVA</strong>
                                    <br /><small class="text-muted">(CA > 400M MGA/an)</small>
                                </div>
                                <div class="col-md-3">
                                    <small class="text-muted">Cohérence globale</small><br />
                                    <strong class="fs-5 @(last.PourcentageCoherenceCA >= 70 ? "text-success" : "text-warning")">
                                        @last.PourcentageCoherenceCA.ToString("F1")%
                                    </strong>
                                    <br /><small class="text-muted">(ratio 0.5-2.0)</small>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">CA moyen/employé/jour</small><br />
                                    <strong class="fs-5">@FormatMGA(last.CAMoyenParEmploye)</strong>
                                </div>
                            </div>
                            <hr />
                            <div class="row text-center">
                                <div class="col-md-4">
                                    <div class="p-2 border rounded">
                                        <small class="fw-bold text-primary">🧵 Textile Export</small><br />
                                        <strong>@FormatMGA(last.CAMoyenParEmployeTextile)</strong>/j
                                        <br /><small class="text-muted">Attendu: 27-55k MGA</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-2 border rounded">
                                        <small class="fw-bold text-success">🏪 Commerce/Services</small><br />
                                        <strong>@FormatMGA(last.CAMoyenParEmployeCommerce)</strong>/j
                                        <br /><small class="text-muted">Attendu: 73-110k MGA</small>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-2 border rounded">
                                        <small class="fw-bold text-warning">⛏️ Secteur Minier</small><br />
                                        <strong>@FormatMGA(last.CAMoyenParEmployeMinier)</strong>/j
                                        <br /><small class="text-muted">Attendu: 200-274k MGA</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tableaux de données -->
            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-3">
                        <div class="card-header bg-info text-white">
                            🏠 Évolution des ménages
                        </div>
                        <div class="card-body card-body-scroll">
                            <table class="table table-sm table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Jour</th>
                                        <th>Épargne totale</th>
                                        <th>Consommation</th>
                                        <th>Emploi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var snap in GetSampledSnapshots())
                                    {
                                        <tr>
                                            <td>@snap.Jour</td>
                                            <td>@FormatMGA(snap.EpargneTotaleMenages)</td>
                                            <td>@FormatMGA(snap.ConsommationTotaleMenages)</td>
                                            <td>@((snap.TauxEmploi * 100).ToString("F0"))%</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-3">
                        <div class="card-header bg-success text-white">
                            🏢 Évolution des entreprises
                        </div>
                        <div class="card-body card-body-scroll">
                            <table class="table table-sm table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Jour</th>
                                        <th>CA total</th>
                                        <th>Trésorerie moy.</th>
                                        <th>Bénéfice</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var snap in GetSampledSnapshots())
                                    {
                                        <tr>
                                            <td>@snap.Jour</td>
                                            <td>@FormatMGA(snap.ChiffreAffairesTotalEntreprises)</td>
                                            <td>@FormatMGA(snap.TresorerieMoyenneEntreprises)</td>
                                            <td>@FormatMGA(snap.BeneficeTotalEntreprises)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-3">
                        <div class="card-header bg-warning">
                            🏛️ Finances publiques
                        </div>
                        <div class="card-body card-body-scroll">
                            <table class="table table-sm table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Jour</th>
                                        <th>Recettes cumulées</th>
                                        <th>Solde budgétaire</th>
                                        <th>Dette</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var snap in GetSampledSnapshots())
                                    {
                                        <tr>
                                            <td>@snap.Jour</td>
                                            <td>@FormatMGA(snap.RecettesFiscalesTotales)</td>
                                            <td class="@(snap.SoldeBudgetaire >= 0 ? "text-success" : "text-danger")">
                                                @FormatMGA(snap.SoldeBudgetaire)
                                            </td>
                                            <td>@FormatMGA(snap.DettePublique)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-3">
                        <div class="card-header bg-secondary text-white">
                            📊 Indicateurs macro & Commerce
                        </div>
                        <div class="card-body card-body-scroll">
                            <table class="table table-sm table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Jour</th>
                                        <th>PIB proxy</th>
                                        <th>Imports</th>
                                        <th>Exports</th>
                                        <th>Balance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var snap in GetSampledSnapshots())
                                    {
                                        <tr>
                                            <td>@snap.Jour</td>
                                            <td>@FormatMGA(snap.PIBProxy)</td>
                                            <td>@FormatMGA(snap.ImportationsCIF)</td>
                                            <td>@FormatMGA(snap.ExportationsFOB)</td>
                                            <td class="@(snap.BalanceCommerciale >= 0 ? "text-success" : "text-danger")">
                                                @FormatMGA(snap.BalanceCommerciale)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Résumé final -->
            @if (Simulator.Result.EstTerminee)
            {
                var first = Simulator.Result.Snapshots[0];
                <div class="card border-dark mt-3">
                    <div class="card-header bg-dark text-white">
                        📋 Bilan de simulation - @_config.Name (@FormatTemps(_config.DureeJours))
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <h6>🏠 Ménages</h6>
                                <ul class="list-unstyled summary-table">
                                    <li>Épargne initiale → finale : @FormatMGA(first.EpargneTotaleMenages) → <strong>@FormatMGA(last.EpargneTotaleMenages)</strong></li>
                                    <li>Variation : <span class="@(last.EpargneTotaleMenages >= first.EpargneTotaleMenages ? "text-success" : "text-danger")">
                                        @FormatPourcent(last.EpargneTotaleMenages, first.EpargneTotaleMenages)
                                    </span></li>
                                    <li>Taux d'emploi final : @((last.TauxEmploi * 100).ToString("F1"))%</li>
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <h6>🏢 Entreprises</h6>
                                <ul class="list-unstyled summary-table">
                                    <li>Trésorerie moy. : @FormatMGA(first.TresorerieMoyenneEntreprises) → <strong>@FormatMGA(last.TresorerieMoyenneEntreprises)</strong></li>
                                    <li>Variation : <span class="@(last.TresorerieMoyenneEntreprises >= first.TresorerieMoyenneEntreprises ? "text-success" : "text-danger")">
                                        @FormatPourcent(last.TresorerieMoyenneEntreprises, first.TresorerieMoyenneEntreprises)
                                    </span></li>
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <h6>🏛️ État</h6>
                                <ul class="list-unstyled summary-table">
                                    <li>Recettes fiscales totales : <strong>@FormatMGA(last.RecettesFiscalesTotales)</strong></li>
                                    <li>Solde budgétaire : <span class="@(last.SoldeBudgetaire >= 0 ? "text-success fw-bold" : "text-danger fw-bold")">@FormatMGA(last.SoldeBudgetaire)</span></li>
                                    <li>Dette publique : <strong>@FormatMGA(last.DettePublique)</strong></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── Journal de recalibration mensuelle ── *@
                @if (Simulator.Result.CalibrationEvents.Count > 0)
                {
                    <div class="card border-warning mt-3">
                        <div class="card-header bg-warning text-dark">
                            🔄 Recalibrations mensuelles (@Simulator.Result.CalibrationEvents.Count événements)
                        </div>
                        <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                            @foreach (var evt in Simulator.Result.CalibrationEvents)
                            {
                                <div class="card mb-2">
                                    <div class="card-header py-1 bg-light">
                                        <strong>📅 Jour @evt.Jour (Mois @evt.Mois)</strong>
                                        <span class="badge bg-info ms-2">@evt.Ajustements.Count corrections</span>
                                    </div>
                                    <div class="card-body p-2">
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Paramètre</th>
                                                    <th>Simulé</th>
                                                    <th>Cible</th>
                                                    <th>Écart</th>
                                                    <th>Correction</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var adj in evt.Ajustements)
                                                {
                                                    <tr>
                                                        <td><code>@adj.Parametre</code></td>
                                                        <td>@FormatMds(adj.ValeurSimulee)</td>
                                                        <td>@FormatMds(adj.ValeurCible)</td>
                                                        <td class="@(Math.Abs(adj.EcartPourcent) < 5 ? "text-success" : Math.Abs(adj.EcartPourcent) < 20 ? "text-warning" : "text-danger")">
                                                            @(adj.EcartPourcent >= 0 ? "+" : "")@adj.EcartPourcent.ToString("F1")%
                                                        </td>
                                                        <td>
                                                            <small>@FormatSmallNumber(adj.AncienneValeur) → <strong>@FormatSmallNumber(adj.NouvelleValeur)</strong></small>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* ── Bouton intégration AIDS ── *@
                <div class="card border-info mt-3">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <strong>🧮 Analyser avec le modèle AIDS</strong>
                            <p class="mb-0 small text-muted">
                                Exportez les parts budgétaires observées vers le modèle AIDS pour estimer les paramètres
                                d'élasticité et définir un objectif de croissance M3.
                            </p>
                        </div>
                        <a href="/aids-croissance" class="btn btn-info btn-lg">
                            📊 Ouvrir AIDS →
                        </a>
                    </div>
                </div>
        }
        else if (!Simulator.EnCours)
        {
            <div class="alert alert-info">
                <h5>📌 Comment utiliser le simulateur</h5>
                <ol>
                    <li>Choisissez un <strong>scénario prédéfini</strong> ou ajustez les paramètres manuellement</li>
                    <li>Sélectionnez l'<strong>horizon temporel</strong> (court, moyen ou long terme)</li>
                    <li>Lancez la simulation en <strong>temps réel</strong> (1s = 1 jour) ou en <strong>mode rapide</strong></li>
                    <li>Observez les impacts sur l'épargne des ménages, les recettes fiscales, la dette publique, etc.</li>
                </ol>
                <hr />
                <p class="mb-0"><strong>Hypothèses :</strong> Salaires log-normale (médiane ~170k MGA, Gini ~0.43).
                    IRSA progressif par tranches. Commerce extérieur : importateurs (DD 0-20%, accise 0-60%, TVA import 20%)
                    et exportateurs (vanille, nickel, textile). PIB = C + I + G + (X - M).
                    Transport : public 1 200 MGA/j, moto/voiture selon carburant (~5 500 MGA/L).</p>
                <hr />
                <p class="mb-0"><strong>🍚 Riz :</strong> Consommation ~130 kg/pers/an (source FAO/INSTAT, 1er consommateur d'Afrique).
                    Taille moyenne ménage ~4,5 personnes. Prix riz local ~2 400 MGA/kg, importé ~2 800 MGA/kg.
                    Part importée ~18% (300-500 kt/an sur ~4 Mt consommées). Le coût quotidien du riz est une dépense
                    incompressible déduite avant la consommation discrétionnaire.</p>
                <p class="mb-0"><strong>💧⚡ JIRAMA :</strong> Monopole public (Jiro sy Rano Malagasy) — seul fournisseur d'eau et d'électricité.
                    <em>Source : Tableau 21 JIRAMA/ORE — Évolution mensuelle production & consommation d'électricité (juil. 2023 – juin 2025).</em></p>
                <ul class="mb-0 small">
                    <li><strong>Production :</strong> ~986 023 MWh / semestre (jan-juin 2025). Part hydraulique ~51,6%, thermique ~48,4%.
                        Tendance : production hydraulique -12,7% en 2025 vs 2024 (sécheresse), thermique +12,8%.</li>
                    <li><strong>Prix moyen :</strong> 653 Ar/KWh (cumul jan-juin 2025), contre 624 Ar/KWh en 2024 (+4,7%).
                        Historique : 610 Ar/KWh (juil. 2023) → 672 Ar/KWh (janv. 2025) → 646 Ar/KWh (mai 2025).</li>
                    <li><strong>Consommation :</strong> 701 336 MWh / semestre. Ménages 47,4% (332 284 MWh), Industries 51,9% (363 763 MWh),
                        Éclairage public 0,75% (5 290 MWh). Tendance ménages +0,4%, industrie -7,0%.</li>
                    <li><strong>Par ménage connecté :</strong> ~30,8 KWh/mois (~1,03 KWh/jour). Facture moy. ~20 100 MGA/mois (~670 MGA/jour).
                        Consommation différenciée par classe socio-éco (subsistance ×0.5 → cadre ×2.5).</li>
                    <li><strong>Pertes de distribution :</strong> ~28,9% (norme internationale 8-12%). Reflète la vétusté du réseau.</li>
                    <li><strong>Accès :</strong> électricité ~30% des ménages (65% urbain, 10% rural), eau ~25% (55% urbain, 10% rural).</li>
                    <li><strong>Eau :</strong> facture moy. ~15 000 MGA/mois (~500 MGA/jour).</li>
                </ul>
            </div>
        }
    }
</div>
</div>
