    protected override void OnInitialized() => Nav.NavigateTo("/documentation", replace: true);
}

<div class="container py-4 doc-container">

    <h1>🧮 Modèle Mathématique Tensoriel</h1>
    <p class="lead text-muted">
        Formalisation matricielle du lien entre produits, entreprises, ménages, ventes et masse monétaire.
    </p>

    <hr />

    @* ══════════ TABLE DES MATIÈRES ══════════ *@
    <nav class="card section-card border-secondary mb-4">
        <div class="card-header bg-secondary text-white">📑 Table des matières</div>
        <div class="card-body">
            <ol class="mb-0">
                <li><a href="#notations">Notations et dimensions</a></li>
                <li>
                    <a href="#tenseur-achat">Tenseurs d'achat et de vente</a>
                    <ul>
                        <li><a href="#tenseur-achat">Q — Achats ménages → entreprises (B2C)</a></li>
                        <li><a href="#tenseur-h2h">S — Ventes entre ménages (H2H informel)</a></li>
                    </ul>
                </li>
                <li>
                    <a href="#ventes">Ventes et achats totaux — décomposition en 4 flux</a>
                    <ul>
                        <li><a href="#ventes-b2c">V_B2C — Entreprise → Ménage</a></li>
                        <li><a href="#ventes-h2h">V_H2H — Ménage → Ménage (informel)</a></li>
                        <li><a href="#ventes-export">V_X — Entreprise → Étranger (exports, +MS)</a></li>
                        <li><a href="#achats-import">I_IMP — Étranger → Entreprise (imports, −MS)</a></li>
                    </ul>
                </li>
                <li><a href="#masse-monetaire">Masse monétaire — de V à MS(t)</a></li>
                <li><a href="#flux">Diagramme des flux monétaires</a></li>
                <li><a href="#correspondance">Correspondance avec le code existant</a></li>
                <li><a href="#categories">Catégories de dépenses (N=8) dans la simulation</a></li>
                <li><a href="#couverture">Couverture du modèle et extensions possibles</a></li>
                <li><a href="#estimation-comportementale">Estimation comportementale des paramètres</a></li>
                <li>
                    <a href="#integration-aids">Intégration Simulation ↔ AIDS (boucle complète)</a>
                    <ul>
                        <li><a href="#flux-sim-aids">Flux 1 : Simulation → AIDS (import)</a></li>
                        <li><a href="#flux-aids-sim">Flux 2 : AIDS → Simulation (export)</a></li>
                        <li><a href="#mapping-categories">Mapping des 8 catégories</a></li>
