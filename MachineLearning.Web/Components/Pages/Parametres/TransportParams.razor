@page "/parametres/{ScenarioId:int}/transport"
@using Simulation.Infrastructure; @using Simulation.Infrastructure.Entities
@inject IScenarioRepository Repo
@rendermode InteractiveServer

<PageTitle>Transport — Paramètres</PageTitle>

<ParamModuleLayout ScenarioId="ScenarioId" TitreModule="Transport & Mobilité" IconeModule="🚌" ModuleActif="transport">
    @if (_p == null) { <div class="d-flex justify-content-center py-4"><div class="spinner-border text-primary"></div></div> }
    else
    {
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">🚌 Transport Public (Informel)</div>
                    <div class="card-body row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Part transport public informel dans les achats</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_pubInfPC" min="0" max="100" step="5" /><span class="input-group-text">%</span></div>
                            <div class="form-text">~70% des déplacements urb. = taxi-be/pousse-pousse</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Coût taxi-be (MGA/trajet)</label>
                            <input type="number" class="form-control" @bind="_p.CoutTaxiBe" min="0" step="100" />
                            <div class="form-text">Tarif réglementé Antananarivo 2025 : ~800 MGA</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Coût transport pour paiement JIRAMA (MGA/trajet)</label>
                            <input type="number" class="form-control" @bind="_p.CoutTransportPaiementJirama" min="0" step="100" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">🛵 Véhicules Personnels</div>
                    <div class="card-body row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Consommation moto (L/100 km)</label>
                            <input type="number" class="form-control" @bind="_p.ConsoMotoLitrePour100km" min="0" max="10" step="0.1" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Consommation voiture (L/100 km)</label>
                            <input type="number" class="form-control" @bind="_p.ConsoVoitureLitrePour100km" min="0" max="20" step="0.5" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Entretien voiture (MGA/jour)</label>
                            <input type="number" class="form-control" @bind="_p.EntretienVoitureJour" min="0" step="500" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Part formel dans l'achat de carburant</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_formelPC" min="0" max="100" step="5" /><span class="input-group-text">%</span></div>
                            <div class="form-text">~60% formel (stations Total/Shell), 40% revente informelle</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Part informel dans l'entretien</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_entretienInfPC" min="0" max="100" step="5" /><span class="input-group-text">%</span></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary px-4" @onclick="Sauvegarder" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> } 💾 Sauvegarder
                </button>
                @if (_ok) { <div class="alert alert-success py-2 mb-0">✅ Sauvegardé.</div> }
            </div>
        </div>
    }
</ParamModuleLayout>

@code {
    [Parameter] public int ScenarioId { get; set; }
    private ParamTransportEntity? _p;
    private bool _saving, _ok;
    private double _pubInfPC { get => _p!.PartInformelTransportPublic * 100; set => _p!.PartInformelTransportPublic = value / 100; }
    private double _formelPC { get => _p!.PartFormelCarburant * 100; set => _p!.PartFormelCarburant = value / 100; }
    private double _entretienInfPC { get => _p!.PartInformelEntretien * 100; set => _p!.PartInformelEntretien = value / 100; }
    protected override async Task OnParametersSetAsync()
    {
        _p = await Repo.GetParamTransportAsync(ScenarioId) ?? new ParamTransportEntity { ScenarioId = ScenarioId };
        _ok = false;
    }
    private async Task Sauvegarder()
    {
        _saving = true; _ok = false; _p!.ScenarioId = ScenarioId;
        await Repo.UpsertParamTransportAsync(_p); _saving = false; _ok = true;
    }
}
