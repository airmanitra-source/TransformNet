@page "/parametres/{ScenarioId:int}/banque"
@using Simulation.Infrastructure
@using Simulation.Infrastructure.Entities
@inject IScenarioRepository Repo
@rendermode InteractiveServer

<PageTitle>Banque — Paramètres</PageTitle>

<ParamModuleLayout ScenarioId="ScenarioId" TitreModule="Secteur Bancaire & Monétaire" IconeModule="🏦" ModuleActif="banque">
    @if (_p == null) { <div class="d-flex justify-content-center py-4"><div class="spinner-border text-primary"></div></div> }
    else
    {
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">💵 Taux d'Intérêt (BCM 2024)</div>
                    <div class="card-body row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Taux créditeur (dépôts)</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_depositPC" min="0" max="20" step="0.25" /><span class="input-group-text">%/an</span></div>
                            <div class="form-text">BCM 2024 : ~4–5%</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Taux débiteur (crédits)</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_creditPC" min="0" max="40" step="0.5" /><span class="input-group-text">%/an</span></div>
                            <div class="form-text">BCM 2024 : ~14–18%</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Réserves obligatoires</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_roPC" min="0" max="30" step="0.5" /><span class="input-group-text">%</span></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">🔢 Multiplicateur Monétaire</div>
                    <div class="card-body row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Part dépôts à vue</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_avuePC" min="0" max="100" step="5" /><span class="input-group-text">%</span></div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Part monnaie fiduciaire dans M1</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_fiduPC" min="0" max="100" step="5" /><span class="input-group-text">%</span></div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Ratio M3/M2</label>
                            <input type="number" class="form-control" @bind="_p.RatioM3SurM2" min="1" max="2" step="0.01" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">📋 Crédits & NPL</div>
                    <div class="card-body row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Croissance crédit (jour)</label>
                            <input type="number" class="form-control" @bind="_p.CroissanceCreditJour" min="0" max="0.01" step="0.00001" />
                            <div class="form-text">0.00041 ≈ +15%/an</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Part crédit vers entreprises</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_creditEntPC" min="0" max="100" step="5" /><span class="input-group-text">%</span></div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Probabilité défaut/jour</label>
                            <input type="number" class="form-control" @bind="_p.ProbabiliteDefautCreditJour" min="0" max="0.01" step="0.0001" />
                            <div class="form-text">0.0003 ≈ ~10% NPL/an</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Taux recouvrement NPL/jour</label>
                            <input type="number" class="form-control" @bind="_p.TauxRecouvrementNPLJour" min="0" max="0.05" step="0.0005" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-warning">⚖️ BFM — Liquidité</div>
                    <div class="card-body row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Intensité intervention BFM</label>
                            <input type="range" class="form-range" @bind="_p.IntensiteInterventionBFM" min="0" max="1" step="0.05" />
                            <div class="form-text text-end">@(_p.IntensiteInterventionBFM.ToString("P0"))</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Ratio excédent SCB-RO cible</label>
                            <div class="input-group"><input type="number" class="form-control" @bind="_excedentPC" min="0" max="20" step="0.5" /><span class="input-group-text">%</span></div>
                            <div class="form-text">BFM T3 2025 : ~5.5%</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 d-flex gap-2 align-items-center">
                <button class="btn btn-primary px-4" @onclick="Sauvegarder" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> } 💾 Sauvegarder
                </button>
                @if (_ok) { <div class="alert alert-success py-2 mb-0">✅ Sauvegardé.</div> }
            </div>
        </div>
    }
</ParamModuleLayout>

@code {
    [Parameter] public int ScenarioId { get; set; }
    private ParamBanqueEntity? _p;
    private bool _saving, _ok;

    private double _depositPC { get => _p!.TauxInteretDepots * 100; set => _p!.TauxInteretDepots = value / 100; }
    private double _creditPC { get => _p!.TauxInteretCredits * 100; set => _p!.TauxInteretCredits = value / 100; }
    private double _roPC { get => _p!.TauxReserveObligatoire * 100; set => _p!.TauxReserveObligatoire = value / 100; }
    private double _avuePC { get => _p!.PartDepotsAVue * 100; set => _p!.PartDepotsAVue = value / 100; }
    private double _fiduPC { get => _p!.PartMonnaieCirculationDansM1 * 100; set => _p!.PartMonnaieCirculationDansM1 = value / 100; }
    private double _creditEntPC { get => _p!.PartCreditEntreprises * 100; set => _p!.PartCreditEntreprises = value / 100; }
    private double _excedentPC { get => _p!.RatioExcedentSCBCible * 100; set => _p!.RatioExcedentSCBCible = value / 100; }

    protected override async Task OnParametersSetAsync()
    {
        _p = await Repo.GetParamBanqueAsync(ScenarioId) ?? new ParamBanqueEntity { ScenarioId = ScenarioId };
        _ok = false;
    }

    private async Task Sauvegarder()
    {
        _saving = true; _ok = false;
        _p!.ScenarioId = ScenarioId;
        await Repo.UpsertParamBanqueAsync(_p);
        _saving = false; _ok = true;
    }
}
