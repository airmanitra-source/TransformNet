@page "/donnees-imports"
@rendermode InteractiveServer
@using MachineLearning.Web.Models.Agents.Companies

<PageTitle>Données INSTAT — Importations</PageTitle>

<h1>📦 Importations CIF — Données INSTAT</h1>
<p class="text-muted">
    Données historiques réelles des importations CAF/CIF de Madagascar par catégorie.
    <strong>Source : INSTAT — Tableau 33 (juillet 2023 – juin 2025).</strong>
    Les moyennes journalières calculées à partir de ces données sont utilisées directement dans le simulateur.
</p>

<div class="row">
    <!-- ══════════════ DONNÉES INSTAT ══════════════ -->
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header bg-dark text-white">
                <strong>📊 Tableau 33 — Importations CIF mensuelles (millions MGA) — Source INSTAT</strong>
            </div>
            <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-sm table-striped table-hover">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th>Période</th>
                            <th class="text-end">Total CIF</th>
                            <th class="text-end">Biens alim.</th>
                            <th class="text-end">Riz</th>
                            <th class="text-end">Sucre</th>
                            <th class="text-end">Énergie</th>
                            <th class="text-end">Équipement</th>
                            <th class="text-end">Ciment</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in _donnees)
                        {
                            <tr>
                                <td><strong>@d.Periode</strong></td>
                                <td class="text-end fw-bold">@Fmt(d.TotalCIF)</td>
                                <td class="text-end">@Fmt(d.BiensAlimentaires)</td>
                                <td class="text-end">@Fmt(d.Riz)</td>
                                <td class="text-end">@Fmt(d.Sucre)</td>
                                <td class="text-end">@Fmt(d.Energie)</td>
                                <td class="text-end">@Fmt(d.Equipement)</td>
                                <td class="text-end">@Fmt(d.Ciment)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Variations annuelles -->
        <div class="card mb-3">
            <div class="card-header bg-secondary text-white">
                📉 Variations janv–juin 2025 vs 2024
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var v in ImportHistoricalData.VariationsAnnuelles)
                    {
                        <span class="badge @(v.Value >= 0 ? "bg-success" : "bg-danger") fs-6">
                            @v.Key : @(v.Value >= 0 ? "+" : "")@v.Value.ToString("F1")%
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════ MOYENNES INSTAT ══════════════ -->
    <div class="col-md-4">
        <div class="card mb-3 border-success">
            <div class="card-header bg-success text-white">
                <strong>📐 Moyennes journalières utilisées dans le simulateur</strong>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    Calculées automatiquement : moyenne mensuelle INSTAT ÷ 30 jours.
                    Ces valeurs sont injectées directement dans la simulation.
                </p>
                <table class="table table-sm">
                    <thead class="table-dark">
                        <tr><th>Catégorie</th><th class="text-end">M MGA/jour</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _moyennes)
                        {
                            <tr>
                                <td>@NomCategorie(kv.Key)</td>
                                <td class="text-end fw-bold text-success">@kv.Value.ToString("N1")</td>
                            </tr>
                        }
                        <tr class="table-primary">
                            <td><strong>Total</strong></td>
                            <td class="text-end fw-bold">@_moyennes.Values.Sum().ToString("N1")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <strong>ℹ️ Méthode</strong>
            </div>
            <div class="card-body">
                <p>
                    Le simulateur utilise les <strong>moyennes mensuelles INSTAT</strong> divisées par 30 jours
                    pour obtenir les valeurs CIF journalières par catégorie d'import.
                </p>
                <p>
                    Ce mode d'<strong>injection directe</strong> remplace la simulation des importations
                    par les données réelles, ce qui assure un alignement fiable avec les statistiques officielles.
                </p>
                <p class="mb-0">
                    <span class="badge bg-success">✅ Actif par défaut</span>
                    <code>UseImportCalibresDirectement = true</code>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ImportHistoricalData> _donnees = ImportHistoricalData.DonneesINSTAT();
    private Dictionary<ECategorieImport, double> _moyennes = ImportHistoricalData.MoyenneJournaliereParCategorie();

    private static string Fmt(double valeur) => valeur.ToString("N0");

    private static string NomCategorie(ECategorieImport cat) => cat switch
    {
        ECategorieImport.Alimentaire => "🍚 Alimentaire",
        ECategorieImport.Carburant => "⛽ Énergie",
        ECategorieImport.Vehicule => "🚗 Équipement",
        ECategorieImport.MatierePremiere => "🏗️ Ciment/Mat. premières",
        ECategorieImport.BienConsommation => "🛍️ Biens consommation",
        ECategorieImport.Electronique => "📱 Électronique",
        _ => cat.ToString()
    };
}
