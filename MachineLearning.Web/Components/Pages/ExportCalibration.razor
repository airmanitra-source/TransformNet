@page "/donnees-exports"
@rendermode InteractiveServer
@using MachineLearning.Web.Models.Agents.Companies
@using Company.Module.Models

<PageTitle>Données INSTAT — Exportations</PageTitle>

<h1>📦 Exportations FOB — Données INSTAT</h1>
<p class="text-muted">
    Données historiques réelles des exportations FOB de Madagascar par catégorie.
    <strong>Source : INSTAT — Tableau 32 (octobre 2023 – septembre 2025).</strong>
    Les moyennes journalières calculées à partir de ces données sont utilisées directement dans le simulateur.
</p>

<div class="row">
    <!-- ══════════════ DONNÉES INSTAT ══════════════ -->
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header bg-dark text-white">
                <strong>📊 Tableau 32 — Exportations FOB mensuelles (millions MGA) — Source INSTAT</strong>
            </div>
            <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-sm table-striped table-hover">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th>Période</th>
                            <th class="text-end">Total FOB</th>
                            <th class="text-end">Biens alim.</th>
                            <th class="text-end">Vanille</th>
                            <th class="text-end">Crevettes</th>
                            <th class="text-end">Café</th>
                            <th class="text-end">Girofle</th>
                            <th class="text-end">Prod. miniers</th>
                            <th class="text-end">Zones franches</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in _donnees)
                        {
                            <tr>
                                <td><strong>@d.Periode</strong></td>
                                <td class="text-end fw-bold">@Fmt(d.TotalFOB)</td>
                                <td class="text-end">@Fmt(d.BiensAlimentaires)</td>
                                <td class="text-end">@Fmt(d.Vanille)</td>
                                <td class="text-end">@Fmt(d.Crevettes)</td>
                                <td class="text-end">@Fmt(d.Cafe)</td>
                                <td class="text-end">@Fmt(d.Girofle)</td>
                                <td class="text-end">@Fmt(d.ProduitsMiniers)</td>
                                <td class="text-end">@Fmt(d.ZonesFranches)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Variations annuelles -->
        <div class="card mb-3">
            <div class="card-header bg-secondary text-white">
                📉 Variations janv–sept 2025 vs 2024
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var v in ExportHistoricalData.VariationsAnnuelles)
                    {
                        <span class="badge @(v.Value >= 0 ? "bg-success" : "bg-danger") fs-6">
                            @v.Key : @(v.Value >= 0 ? "+" : "")@v.Value.ToString("F1")%
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════ MOYENNES INSTAT ══════════════ -->
    <div class="col-md-4">
        <div class="card mb-3 border-success">
            <div class="card-header bg-success text-white">
                <strong>📐 Moyennes journalières utilisées dans le simulateur</strong>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    Calculées automatiquement : moyenne mensuelle INSTAT ÷ 30 jours.
                    Ces valeurs sont injectées directement dans la simulation.
                </p>
                <table class="table table-sm">
                    <thead class="table-dark">
                        <tr><th>Catégorie</th><th class="text-end">M MGA/jour</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _moyennes)
                        {
                            <tr>
                                <td>@NomCategorie(kv.Key)</td>
                                <td class="text-end fw-bold text-success">@kv.Value.ToString("N1")</td>
                            </tr>
                        }
                        <tr class="table-primary">
                            <td><strong>Total</strong></td>
                            <td class="text-end fw-bold">@_moyennes.Values.Sum().ToString("N1")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <strong>ℹ️ Méthode</strong>
            </div>
            <div class="card-body">
                <p>
                    Le simulateur utilise les <strong>moyennes mensuelles INSTAT</strong> divisées par 30 jours
                    pour obtenir les valeurs FOB journalières par catégorie d'export.
                </p>
                <p>
                    Ce mode d'<strong>injection directe</strong> remplace la simulation des exportations
                    par les données réelles, ce qui assure un alignement fiable avec les statistiques officielles.
                </p>
                <p class="mb-0">
                    <span class="badge bg-success">✅ Actif par défaut</span>
                    <code>UseExportCalibresDirectement = true</code>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ExportHistoricalData> _donnees = ExportHistoricalData.DonneesINSTAT();
    private Dictionary<ECategorieExport, double> _moyennes = ExportHistoricalData.MoyenneJournaliereParCategorie();

    private static string Fmt(double valeur) => valeur.ToString("N0");

    private static string NomCategorie(ECategorieExport cat) => cat switch
    {
        ECategorieExport.BiensAlimentaires => "🍚 Biens alimentaires",
        ECategorieExport.Vanille => "🌿 Vanille",
        ECategorieExport.Crevettes => "🦐 Crevettes",
        ECategorieExport.Cafe => "☕ Café",
        ECategorieExport.Girofle => "🌶️ Girofle",
        ECategorieExport.ProduitsMiniers => "⛏️ Produits miniers",
        ECategorieExport.ZonesFranches => "🏭 Zones franches",
        _ => cat.ToString()
    };
}
