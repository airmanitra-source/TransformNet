@using Simulation.Module.Config
@using System.Globalization

<div>
    <details class="mb-2">
        <summary class="fw-bold" style="cursor: pointer;">🌀 Chocs climatiques (cyclones)</summary>
        <div class="mt-2">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox"
                       @bind="Config.ChocsCycloniquesActives" disabled="@Disabled" />
                <label class="form-check-label">Activer les chocs cycloniques stochastiques</label>
            </div>

            @if (Config.ChocsCycloniquesActives)
            {
                <div class="mb-2">
                    <label class="form-label">
                        Probabilité cyclone/jour (saison nov-avr) :
                        <strong>@((Config.ProbabiliteCycloneJourSaison * 100).ToString("F2"))%</strong>
                        <span class="text-muted small">→ ~@EstimerCyclonesParAn().ToString("F1") cyclones/an</span>
                    </label>
                    <input type="range" class="form-range" min="0.0005" max="0.010" step="0.0005"
                           value="@Config.ProbabiliteCycloneJourSaison.ToString(CultureInfo.InvariantCulture)"
                           @oninput="OnProbabiliteCycloneJourSaisonInput" disabled="@Disabled" />
                </div>
                <div class="mb-2">
                    <label class="form-label">
                        Probabilité hors saison (mai-oct) :
                        <strong>@((Config.ProbabiliteCycloneJourHorsSaison * 10000).ToString("F1")) pour 10 000</strong>
                    </label>
                    <input type="range" class="form-range" min="0.0000" max="0.002" step="0.0001"
                           value="@Config.ProbabiliteCycloneJourHorsSaison.ToString(CultureInfo.InvariantCulture)"
                           @oninput="OnProbabiliteCycloneJourHorsSaisonInput" disabled="@Disabled" />
                </div>

                <hr class="my-2" />
                <small class="fw-bold">🏗️ Répartition dépenses de reconstruction</small>
                <div class="mb-2">
                    <label class="form-label">
                        Part BTP (maçons, charpentiers) :
                        <strong>@((Config.PartReconstructionBTP * 100).ToString("F0"))%</strong>
                    </label>
                    <input type="range" class="form-range" min="0.20" max="0.80" step="0.01"
                           value="@Config.PartReconstructionBTP.ToString(CultureInfo.InvariantCulture)"
                           @oninput="OnPartReconstructionBTPInput" disabled="@Disabled" />
                </div>
                <div class="mb-2">
                    <label class="form-label">
                        Part quincaillerie (tôle, briques, ciment) :
                        <strong>@((Config.PartReconstructionQuincaillerie * 100).ToString("F0"))%</strong>
                    </label>
                    <input type="range" class="form-range" min="0.10" max="0.60" step="0.01"
                           value="@Config.PartReconstructionQuincaillerie.ToString(CultureInfo.InvariantCulture)"
                           @oninput="OnPartReconstructionQuincaillerieInput" disabled="@Disabled" />
                </div>
                <div class="mb-2">
                    <label class="form-label">
                        Part transport informel (charrettes) :
                        <strong>@((Config.PartReconstructionTransportInformel * 100).ToString("F0"))%</strong>
                    </label>
                    <input type="range" class="form-range" min="0.05" max="0.40" step="0.01"
                           value="@Config.PartReconstructionTransportInformel.ToString(CultureInfo.InvariantCulture)"
                           @oninput="OnPartReconstructionTransportInformelInput" disabled="@Disabled" />
                </div>

                <div class="p-2 border rounded bg-light mt-2">
                    <small class="fw-bold">📊 Calibrage BNGRC / Météo Madagascar :</small>
                    <div class="d-flex flex-wrap gap-1 mt-1">
                        <span class="badge bg-info text-dark">Saison : nov-avr</span>
                        <span class="badge bg-info text-dark">Pic : jan-mars</span>
                        <span class="badge bg-warning text-dark">~1.5 cyclones/an</span>
                        <span class="badge bg-danger">Perte PIB : 1-3%/cyclone</span>
                    </div>
                    <div class="d-flex flex-wrap gap-1 mt-1">
                        <span class="badge bg-success">Reconstruction : +20-50% BTP</span>
                        <span class="badge bg-success">Quincaillerie : +30-80%</span>
                    </div>
                </div>
            }
        </div>
    </details>
</div>

@code {
    [Parameter]
    public ScenarioConfig Config { get; set; } = new ScenarioConfig();

    [Parameter]
    public bool Disabled { get; set; } = false;

    private void OnProbabiliteCycloneJourSaisonInput(ChangeEventArgs e)
    {
        if (TryParseInvariant(e, out var v))
            Config.ProbabiliteCycloneJourSaison = v;
    }

    private void OnProbabiliteCycloneJourHorsSaisonInput(ChangeEventArgs e)
    {
        if (TryParseInvariant(e, out var v))
            Config.ProbabiliteCycloneJourHorsSaison = v;
    }

    private void OnPartReconstructionBTPInput(ChangeEventArgs e)
    {
        if (TryParseInvariant(e, out var v))
            Config.PartReconstructionBTP = v;
    }

    private void OnPartReconstructionQuincaillerieInput(ChangeEventArgs e)
    {
        if (TryParseInvariant(e, out var v))
            Config.PartReconstructionQuincaillerie = v;
    }

    private void OnPartReconstructionTransportInformelInput(ChangeEventArgs e)
    {
        if (TryParseInvariant(e, out var v))
            Config.PartReconstructionTransportInformel = v;
    }

    private static bool TryParseInvariant(ChangeEventArgs e, out double value)
    {
        value = 0;
        if (e?.Value is null)
            return false;

        var s = e.Value.ToString();
        if (string.IsNullOrWhiteSpace(s))
            return false;

        s = s.Replace(',', '.');
        return double.TryParse(s, NumberStyles.Float, CultureInfo.InvariantCulture, out value);
    }

    /// <summary>
    /// Estime le nombre moyen de cyclones par an à partir de la probabilité journalière en saison.
    /// Saison = 180 jours (nov-avr), modulation mensuelle moyenne ~1.1.
    /// </summary>
    private double EstimerCyclonesParAn()
    {
        double joursSaison = 180;
        double modulationMoyenne = 1.1;
        double probParJour = Config.ProbabiliteCycloneJourSaison * modulationMoyenne;
        return probParJour * joursSaison;
    }
}
