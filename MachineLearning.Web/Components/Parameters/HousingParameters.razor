@using Simulation.Module.Config

<div>
    <details class="mb-2">
        <summary class="fw-bold" style="cursor: pointer;">🏘️ Logement, loyers et auto-construction</summary>
        <div class="mt-2">
            <div class="mb-2">
                <label class="form-label">Taux de propriétaires : <strong>@((Config.TauxMenagesProprietaires * 100).ToString("F0"))%</strong></label>
                <input type="range" class="form-range" min="0.10" max="0.95" step="0.01"
                       @bind="Config.TauxMenagesProprietaires" @bind:event="oninput" disabled="@Disabled" />
            </div>
            <div class="mb-2">
                <label class="form-label">Loyer journalier locataire : <strong>@FormatMGA(Config.LoyerJourLocataire)</strong></label>
                <input type="range" class="form-range" min="500" max="20000" step="100"
                       @bind="Config.LoyerJourLocataire" @bind:event="oninput" disabled="@Disabled" />
            </div>
            <div class="mb-2">
                <label class="form-label">Probabilité de construction chez les locataires : <strong>@((Config.ProbabiliteConstructionMaisonLocataire * 100).ToString("F0"))%</strong></label>
                <input type="range" class="form-range" min="0.00" max="0.40" step="0.01"
                       @bind="Config.ProbabiliteConstructionMaisonLocataire" @bind:event="oninput" disabled="@Disabled" />
            </div>
            <div class="mb-2">
                <label class="form-label">Durée de construction : <strong>@FormatTemps(Config.DureeConstructionMaisonJours)</strong></label>
                <input type="range" class="form-range" min="30" max="720" step="10"
                       @bind="Config.DureeConstructionMaisonJours" @bind:event="oninput" disabled="@Disabled" />
            </div>
            <div class="mb-2">
                <label class="form-label">Budget journalier de construction : <strong>@FormatMGA(Config.BudgetConstructionMaisonJour)</strong></label>
                <input type="range" class="form-range" min="500" max="30000" step="100"
                       @bind="Config.BudgetConstructionMaisonJour" @bind:event="oninput" disabled="@Disabled" />
            </div>
            <div class="mb-2">
                <label class="form-label">Part BTP : <strong>@((Config.PartBudgetConstructionBTP * 100).ToString("F0"))%</strong></label>
                <input type="range" class="form-range" min="0.10" max="0.80" step="0.01"
                       @bind="Config.PartBudgetConstructionBTP" @bind:event="oninput" disabled="@Disabled" />
            </div>
            <div class="mb-2">
                <label class="form-label">Part quincaillerie : <strong>@((Config.PartBudgetConstructionQuincaillerie * 100).ToString("F0"))%</strong></label>
                <input type="range" class="form-range" min="0.05" max="0.70" step="0.01"
                       @bind="Config.PartBudgetConstructionQuincaillerie" @bind:event="oninput" disabled="@Disabled" />
            </div>
            <div class="mb-2">
                <label class="form-label">Part transport informel briques/matériaux : <strong>@((Config.PartBudgetConstructionTransportInformel * 100).ToString("F0"))%</strong></label>
                <input type="range" class="form-range" min="0.00" max="0.50" step="0.01"
                       @bind="Config.PartBudgetConstructionTransportInformel" @bind:event="oninput" disabled="@Disabled" />
            </div>
        </div>
    </details>
</div>

@code {
    [Parameter]
    public ScenarioConfig Config { get; set; } = new ScenarioConfig();

    [Parameter]
    public bool Disabled { get; set; }

    private static string FormatMGA(double montant)
    {
        if (Math.Abs(montant) >= 1_000_000_000)
            return $"{montant / 1_000_000_000:F2} Mrd MGA";
        if (Math.Abs(montant) >= 1_000_000)
            return $"{montant / 1_000_000:F2} M MGA";
        if (Math.Abs(montant) >= 1_000)
            return $"{montant / 1_000:F1} k MGA";
        return $"{montant:F0} MGA";
    }

    private static string FormatTemps(int jours)
    {
        if (jours >= 365)
        {
            int ans = jours / 365;
            int moisRestants = (jours % 365) / 30;
            return moisRestants > 0 ? $"{ans} an(s) {moisRestants} mois" : $"{ans} an(s)";
        }
        if (jours >= 30)
            return $"{jours / 30} mois";
        return $"{jours} jour(s)";
    }
}
