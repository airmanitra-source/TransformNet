@using Simulation.Module.Config

<div>
    <hr />
    <h6>🔄 Recalibration mensuelle</h6>
    <p class="small text-muted">
        Ancrage sur données macro observées (BCM, INSTAT, DGI).
        À chaque fin de mois, la simulation ajuste ses paramètres pour converger vers la réalité.
    </p>

    <div class="form-check form-switch mb-2">
        <input class="form-check-input" type="checkbox" id="recalibSwitch"
               @bind="Config.RecalibrationMensuelleActivee" disabled="@Disabled" />
        <label class="form-check-label" for="recalibSwitch">
            Activer la recalibration mensuelle
        </label>
    </div>

    @if (Config.RecalibrationMensuelleActivee)
    {
        <div class="mb-2">
            <label class="form-label">Vitesse de convergence : <strong>@((Config.VitesseConvergenceRecalibration * 100).ToString("F0"))%</strong></label>
            <input type="range" class="form-range" min="0.1" max="1.0" step="0.1"
                   @bind="Config.VitesseConvergenceRecalibration" @bind:event="oninput" disabled="@Disabled" />
            <div class="d-flex justify-content-between">
                <small class="text-success">Douce (10%)</small>
                <small class="text-danger">Totale (100%)</small>
            </div>
        </div>

        <div class="mb-2">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <strong class="small">Cibles mensuelles</strong>
                <button class="btn btn-sm btn-outline-primary" @onclick="AjouterCibleMensuelle"
                        disabled="@Disabled">+ Ajouter mois</button>
            </div>

            @if (Config.CiblesMensuelles.Count == 0)
            {
                <div class="alert alert-secondary py-1 small">
                    Aucune cible définie. Cliquez "Ajouter mois" pour entrer les données macro observées.
                </div>
            }
            else
            {
                <div style="max-height: 300px; overflow-y: auto;">
                    @foreach (var cible in Config.CiblesMensuelles.OrderBy(c => c.Mois))
                    {
                        <div class="card mb-1">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="small">📅 Mois @cible.Mois @(!string.IsNullOrEmpty(cible.Label) ? $"({cible.Label})" : "")</strong>
                                    <button class="btn btn-sm btn-outline-danger py-0 px-1"
                                            @onclick="() => SupprimerCibleMensuelle(cible.Mois)"
                                            disabled="@Disabled">✕</button>
                                </div>
                                <div class="row g-1">
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">🏦 M3 (Mds MGA)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.M3Cible.HasValue ? (cible.M3Cible.Value / 1_000_000_000).ToString("F0") : "")"
                                               @onchange="(e) => SetCibleM3(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 30000" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">💰 Recettes fisc. (Mds)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.RecettesFiscalesCumuleesCible.HasValue ? (cible.RecettesFiscalesCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                               @onchange="(e) => SetCibleFiscale(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 1500" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">📦 Exports FOB (Mds)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.ExportationsFOBCumuleesCible.HasValue ? (cible.ExportationsFOBCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                               @onchange="(e) => SetCibleExports(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 1100" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">🚢 Imports CIF (Mds)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.ImportationsCIFCumuleesCible.HasValue ? (cible.ImportationsCIFCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                               @onchange="(e) => SetCibleImports(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 1500" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">🏨 Devises tourisme (Mds)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.DevisesTourismeCible.HasValue ? (cible.DevisesTourismeCible.Value / 1_000_000_000).ToString("F1") : "")"
                                               @onchange="(e) => SetCibleTourisme(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 50" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">👷 Nv. affiliés CNaPS</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.NouveauxAffiliesCNaPSCible?.ToString() ?? "")"
                                               @onchange="(e) => SetCibleCNaPS(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 5000" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public ScenarioConfig Config { get; set; } = new ScenarioConfig();

    [Parameter]
    public bool Disabled { get; set; } = false;

    private void AjouterCibleMensuelle()
    {
        int prochainMois = Config.CiblesMensuelles.Count > 0
            ? Config.CiblesMensuelles.Max(c => c.Mois) + 1
            : 1;

        Config.CiblesMensuelles.Add(new MonthlyCalibrationTarget
        {
            Mois = prochainMois,
            Label = $"Mois {prochainMois}"
        });
    }

    private void SupprimerCibleMensuelle(int mois)
    {
        Config.CiblesMensuelles.RemoveAll(c => c.Mois == mois);
    }

    private static void SetCibleM3(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.M3Cible = val * 1_000_000_000;
        else
            cible.M3Cible = null;
    }

    private static void SetCibleFiscale(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.RecettesFiscalesCumuleesCible = val * 1_000_000_000;
        else
            cible.RecettesFiscalesCumuleesCible = null;
    }

    private static void SetCibleExports(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.ExportationsFOBCumuleesCible = val * 1_000_000_000;
        else
            cible.ExportationsFOBCumuleesCible = null;
    }

    private static void SetCibleImports(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.ImportationsCIFCumuleesCible = val * 1_000_000_000;
        else
            cible.ImportationsCIFCumuleesCible = null;
    }

    private static void SetCibleTourisme(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.DevisesTourismeCible = val * 1_000_000_000;
        else
            cible.DevisesTourismeCible = null;
    }

    private static void SetCibleCNaPS(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val) && val > 0)
            cible.NouveauxAffiliesCNaPSCible = val;
        else
            cible.NouveauxAffiliesCNaPSCible = null;
    }
}
