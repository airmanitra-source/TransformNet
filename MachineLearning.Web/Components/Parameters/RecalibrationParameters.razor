@using Simulation.Module.Config
@using Simulation.Module.Models

<div>
    <hr />
    <h6>🔄 Recalibration mensuelle</h6>
    <p class="small text-muted">
        Ancrage sur données macro observées (BCM, INSTAT, DGI).
        À chaque fin de mois, la simulation ajuste ses paramètres pour converger vers la réalité.
    </p>

    <div class="form-check form-switch mb-2">
        <input class="form-check-input" type="checkbox" id="recalibSwitch"
               @bind="Config.RecalibrationMensuelleActivee" disabled="@Disabled" />
        <label class="form-check-label" for="recalibSwitch">
            Activer la recalibration mensuelle
        </label>
    </div>

    @if (Config.RecalibrationMensuelleActivee)
    {
        <div class="mb-2">
            <label class="form-label">Vitesse de convergence : <strong>@((Config.VitesseConvergenceRecalibration * 100).ToString("F0"))%</strong></label>
            <input type="range" class="form-range" min="0.1" max="1.0" step="0.1"
                   @bind="Config.VitesseConvergenceRecalibration" @bind:event="oninput" disabled="@Disabled" />
            <div class="d-flex justify-content-between">
                <small class="text-success">Douce (10%)</small>
                <small class="text-danger">Totale (100%)</small>
            </div>
        </div>

        <!-- ══════════ Scraping automatique Banque Mondiale ══════════ -->
        <div class="card mb-2 border-info">
            <div class="card-body p-2">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <strong class="small">🌐 Collecte automatique (Banque Mondiale)</strong>
                </div>
                <p class="small text-muted mb-1">
                    Récupère PIB, inflation, commerce, réserves, remittances depuis l'API ouverte WDI
                    et peuple automatiquement les paramètres du scénario + cibles mensuelles.
                </p>
                <div class="d-flex gap-2 align-items-center">
                    <input type="number" class="form-control form-control-sm" style="width: 80px;"
                           @bind="_anneeCollecte" disabled="@(Disabled || _enCoursCollecte)" placeholder="Année" />
                    <button class="btn btn-sm btn-info text-white" disabled="@(Disabled || _enCoursCollecte)"
                            @onclick="LancerCollecteAsync">
                        @if (_enCoursCollecte)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Collecte…</span>
                        }
                        else
                        {
                            <span>🔍 Scraper les données</span>
                        }
                    </button>
                </div>

                @if (_derniereCollecte != null)
                {
                    <div class="mt-2">
                        @if (_derniereCollecte.EstExploitable)
                        {
                            <div class="alert alert-success py-1 px-2 small mb-1">
                                ✅ Données @(_derniereCollecte.Annee) collectées (@_derniereCollecte.DateCollecte.ToString("dd/MM/yyyy HH:mm"))
                                — @_derniereCollecte.Sources.FirstOrDefault()
                            </div>
                            <div class="row g-1 small">
                                @if (_derniereCollecte.PIBNominalAnnuelLCU.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-secondary">PIB</span> @FormatMds(_derniereCollecte.PIBNominalAnnuelLCU.Value) Mds MGA</div>
                                }
                                @if (_derniereCollecte.TauxInflationAnnuel.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-warning text-dark">Inflation</span> @((_derniereCollecte.TauxInflationAnnuel.Value * 100).ToString("F1"))%</div>
                                }
                                @if (_derniereCollecte.TauxChangeOfficielLCUParUSD.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-primary">Change</span> @_derniereCollecte.TauxChangeOfficielLCUParUSD.Value.ToString("N0") MGA/USD</div>
                                }
                                @if (_derniereCollecte.ReservesTotalesUSD.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-info text-white">Réserves</span> @FormatMdsUSD(_derniereCollecte.ReservesTotalesUSD.Value)</div>
                                }
                                @if (_derniereCollecte.RemittancesRecuesUSD.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-success">Remittances</span> @FormatMdsUSD(_derniereCollecte.RemittancesRecuesUSD.Value)</div>
                                }
                                @if (_derniereCollecte.CroissanceDemographique.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-dark">Démographie</span> +@((_derniereCollecte.CroissanceDemographique.Value * 100).ToString("F1"))%/an</div>
                                }
                                @if (_derniereCollecte.ExportationsUSD.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-success">Exports</span> @FormatMdsUSD(_derniereCollecte.ExportationsUSD.Value)</div>
                                }
                                @if (_derniereCollecte.ImportationsUSD.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-danger">Imports</span> @FormatMdsUSD(_derniereCollecte.ImportationsUSD.Value)</div>
                                }
                                @if (_derniereCollecte.RecettesTouristiquesUSD.HasValue)
                                {
                                    <div class="col-6"><span class="badge bg-info text-white">Tourisme</span> @FormatMdsUSD(_derniereCollecte.RecettesTouristiquesUSD.Value)</div>
                                }
                            </div>
                            <button class="btn btn-sm btn-success w-100 mt-1" @onclick="AppliquerCollecte" disabled="@Disabled">
                                ✅ Appliquer au scénario + générer 12 cibles mensuelles
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-warning py-1 px-2 small mb-0">
                                ⚠️ Données insuffisantes pour calibrer le modèle.
                            </div>
                        }

                        @if (_derniereCollecte.Erreurs.Count > 0)
                        {
                            <details class="mt-1">
                                <summary class="small text-muted">@_derniereCollecte.Erreurs.Count indicateur(s) manquant(s)</summary>
                                <ul class="small text-muted mb-0">
                                    @foreach (var err in _derniereCollecte.Erreurs.Take(5))
                                    {
                                        <li>@err</li>
                                    }
                                </ul>
                            </details>
                        }
                    </div>
                }
            </div>
        </div>
        <!-- ══════════════════════════════════════════════════════════════ -->

        <!-- ══════════ Scraping INSTAT TBE ══════════ -->
        <div class="card mb-2 border-success">
            <div class="card-body p-2">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <strong class="small">📊 INSTAT — Tableau de Bord Économique (TBE)</strong>
                </div>
                <p class="small text-muted mb-1">
                    Télécharge le dernier TBE (PDF) depuis instat.mg et extrait les séries mensuelles réelles :
                    M3, recettes fiscales, exports/imports, tourisme, affiliés CNaPS.
                </p>
                <div class="d-flex gap-2 align-items-center">
                    <button class="btn btn-sm btn-success text-white" disabled="@(Disabled || _enCoursInstat)"
                            @onclick="LancerCollecteInstatAsync">
                        @if (_enCoursInstat)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Téléchargement TBE…</span>
                        }
                        else
                        {
                            <span>📥 Scraper le TBE INSTAT</span>
                        }
                    </button>
                </div>

                @if (_derniereCollecteInstat != null)
                {
                    <div class="mt-2">
                        @if (_derniereCollecteInstat.EstExploitable)
                        {
                            <div class="alert alert-success py-1 px-2 small mb-1">
                                ✅ TBE N°@_derniereCollecteInstat.NumeroTbe — @_derniereCollecteInstat.PeriodeReference
                                (@_derniereCollecteInstat.Mois.Count mois extraits)
                            </div>
                            <div class="row g-1 small">
                                @{
                                    var dernierMois = _derniereCollecteInstat.Mois.FirstOrDefault();
                                }
                                @if (dernierMois?.M3Mds != null)
                                {
                                    <div class="col-6"><span class="badge bg-primary">M3</span> @dernierMois.M3Mds.Value.ToString("N0") Mds MGA</div>
                                }
                                @if (dernierMois?.RecettesFiscalesCumulMds != null)
                                {
                                    <div class="col-6"><span class="badge bg-warning text-dark">Fisc.</span> @dernierMois.RecettesFiscalesCumulMds.Value.ToString("N0") Mds cumul</div>
                                }
                                @if (dernierMois?.ExportsFobMillions != null)
                                {
                                    <div class="col-6"><span class="badge bg-success">Exp. FOB</span> @(dernierMois.ExportsFobMillions.Value / 1000).ToString("N0") Mds</div>
                                }
                                @if (dernierMois?.ImportsCifMillions != null)
                                {
                                    <div class="col-6"><span class="badge bg-danger">Imp. CIF</span> @(dernierMois.ImportsCifMillions.Value / 1000).ToString("N0") Mds</div>
                                }
                                @if (dernierMois?.ArriveesTouristes != null)
                                {
                                    <div class="col-6"><span class="badge bg-info text-white">Touristes</span> @dernierMois.ArriveesTouristes.Value.ToString("N0")</div>
                                }
                                @if (dernierMois?.NouveauxAffiliesCNaPS != null)
                                {
                                    <div class="col-6"><span class="badge bg-dark">CNaPS</span> @dernierMois.NouveauxAffiliesCNaPS.Value.ToString("N0") nouveaux</div>
                                }
                            </div>
                            <button class="btn btn-sm btn-success w-100 mt-1" @onclick="AppliquerInstat" disabled="@Disabled">
                                ✅ Appliquer les données TBE aux cibles mensuelles
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-warning py-1 px-2 small mb-0">
                                ⚠️ Aucune donnée exploitable extraite du TBE.
                            </div>
                        }

                        @if (_derniereCollecteInstat.Erreurs.Count > 0)
                        {
                            <details class="mt-1">
                                <summary class="small text-muted">@_derniereCollecteInstat.Erreurs.Count erreur(s) de parsing</summary>
                                <ul class="small text-muted mb-0">
                                    @foreach (var err in _derniereCollecteInstat.Erreurs)
                                    {
                                        <li>@err</li>
                                    }
                                </ul>
                            </details>
                        }
                    </div>
                }
            </div>
        </div>
        <!-- ══════════════════════════════════════════════════════════════ -->

        <div class="mb-2">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <strong class="small">Cibles mensuelles</strong>
                <button class="btn btn-sm btn-outline-primary" @onclick="AjouterCibleMensuelle"
                        disabled="@Disabled">+ Ajouter mois</button>
            </div>

            @if (Config.CiblesMensuelles.Count == 0)
            {
                <div class="alert alert-secondary py-1 small">
                    Aucune cible définie. Cliquez "Ajouter mois" pour entrer les données macro observées.
                </div>
            }
            else
            {
                <div style="max-height: 300px; overflow-y: auto;">
                    @foreach (var cible in Config.CiblesMensuelles.OrderBy(c => c.Mois))
                    {
                        <div class="card mb-1">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="small">📅 Mois @cible.Mois @(!string.IsNullOrEmpty(cible.Label) ? $"({cible.Label})" : "")</strong>
                                    <button class="btn btn-sm btn-outline-danger py-0 px-1"
                                            @onclick="() => SupprimerCibleMensuelle(cible.Mois)"
                                            disabled="@Disabled">✕</button>
                                </div>
                                <div class="row g-1">
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">🏦 M3 (Mds MGA)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.M3Cible.HasValue ? (cible.M3Cible.Value / 1_000_000_000).ToString("F0") : "")"
                                               @onchange="(e) => SetCibleM3(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 30000" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">💰 Recettes fisc. (Mds)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.RecettesFiscalesCumuleesCible.HasValue ? (cible.RecettesFiscalesCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                               @onchange="(e) => SetCibleFiscale(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 1500" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">📦 Exports FOB (Mds)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.ExportationsFOBCumuleesCible.HasValue ? (cible.ExportationsFOBCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                               @onchange="(e) => SetCibleExports(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 1100" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">🚢 Imports CIF (Mds)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.ImportationsCIFCumuleesCible.HasValue ? (cible.ImportationsCIFCumuleesCible.Value / 1_000_000_000).ToString("F0") : "")"
                                               @onchange="(e) => SetCibleImports(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 1500" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">🏨 Devises tourisme (Mds)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.DevisesTourismeCible.HasValue ? (cible.DevisesTourismeCible.Value / 1_000_000_000).ToString("F1") : "")"
                                               @onchange="(e) => SetCibleTourisme(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 50" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label mb-0 small">👷 Nv. affiliés CNaPS</label>
                                        <input type="number" class="form-control form-control-sm"
                                               value="@(cible.NouveauxAffiliesCNaPSCible?.ToString() ?? "")"
                                               @onchange="(e) => SetCibleCNaPS(cible, e)"
                                               disabled="@Disabled" placeholder="ex: 5000" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public ScenarioConfig Config { get; set; } = new ScenarioConfig();

    [Parameter]
    public bool Disabled { get; set; } = false;

    /// <summary>
    /// Callback pour déclencher la collecte via le service injecté dans la page parente.
    /// Retourne les données collectées pour affichage.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnCollecterDonnees { get; set; }

    /// <summary>
    /// Callback pour appliquer les données collectées au scénario.
    /// </summary>
    [Parameter]
    public EventCallback OnAppliquerDonnees { get; set; }

    /// <summary>
    /// Dernières données collectées (alimenté par la page parente).
    /// </summary>
    [Parameter]
    public MacroeconomicScrapedData? DerniereCollecte { get; set; }

    /// <summary>
    /// Callback pour déclencher la collecte INSTAT TBE.
    /// </summary>
    [Parameter]
    public EventCallback OnCollecterInstat { get; set; }

    /// <summary>
    /// Callback pour appliquer les données TBE aux cibles.
    /// </summary>
    [Parameter]
    public EventCallback OnAppliquerInstat { get; set; }

    /// <summary>
    /// Dernières données TBE INSTAT collectées (alimenté par la page parente).
    /// </summary>
    [Parameter]
    public InstatTbeData? DerniereCollecteInstat { get; set; }

    private bool _enCoursCollecte = false;
    private bool _enCoursInstat = false;
    private int _anneeCollecte = DateTime.UtcNow.Year - 1;
    private MacroeconomicScrapedData? _derniereCollecte;
    private InstatTbeData? _derniereCollecteInstat;

    protected override void OnParametersSet()
    {
        if (DerniereCollecte != null)
            _derniereCollecte = DerniereCollecte;
        if (DerniereCollecteInstat != null)
            _derniereCollecteInstat = DerniereCollecteInstat;
    }

    private async Task LancerCollecteAsync()
    {
        _enCoursCollecte = true;
        try
        {
            await OnCollecterDonnees.InvokeAsync(_anneeCollecte);
            _derniereCollecte = DerniereCollecte;
        }
        finally
        {
            _enCoursCollecte = false;
        }
    }

    private async Task AppliquerCollecte()
    {
        await OnAppliquerDonnees.InvokeAsync();
    }

    private async Task LancerCollecteInstatAsync()
    {
        _enCoursInstat = true;
        try
        {
            await OnCollecterInstat.InvokeAsync();
            _derniereCollecteInstat = DerniereCollecteInstat;
        }
        finally
        {
            _enCoursInstat = false;
        }
    }

    private async Task AppliquerInstat()
    {
        await OnAppliquerInstat.InvokeAsync();
    }

    private static string FormatMds(double valeur)
    {
        return (valeur / 1_000_000_000).ToString("N0");
    }

    private static string FormatMdsUSD(double valeur)
    {
        if (Math.Abs(valeur) >= 1_000_000_000)
            return $"{valeur / 1_000_000_000:F2} Mds USD";
        if (Math.Abs(valeur) >= 1_000_000)
            return $"{valeur / 1_000_000:F1} M USD";
        return $"{valeur:N0} USD";
    }

    private void AjouterCibleMensuelle()
    {
        int prochainMois = Config.CiblesMensuelles.Count > 0
            ? Config.CiblesMensuelles.Max(c => c.Mois) + 1
            : 1;

        Config.CiblesMensuelles.Add(new MonthlyCalibrationTarget
        {
            Mois = prochainMois,
            Label = $"Mois {prochainMois}"
        });
    }

    private void SupprimerCibleMensuelle(int mois)
    {
        Config.CiblesMensuelles.RemoveAll(c => c.Mois == mois);
    }

    private static void SetCibleM3(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.M3Cible = val * 1_000_000_000;
        else
            cible.M3Cible = null;
    }

    private static void SetCibleFiscale(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.RecettesFiscalesCumuleesCible = val * 1_000_000_000;
        else
            cible.RecettesFiscalesCumuleesCible = null;
    }

    private static void SetCibleExports(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.ExportationsFOBCumuleesCible = val * 1_000_000_000;
        else
            cible.ExportationsFOBCumuleesCible = null;
    }

    private static void SetCibleImports(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.ImportationsCIFCumuleesCible = val * 1_000_000_000;
        else
            cible.ImportationsCIFCumuleesCible = null;
    }

    private static void SetCibleTourisme(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val) && val > 0)
            cible.DevisesTourismeCible = val * 1_000_000_000;
        else
            cible.DevisesTourismeCible = null;
    }

    private static void SetCibleCNaPS(MonthlyCalibrationTarget cible, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val) && val > 0)
            cible.NouveauxAffiliesCNaPSCible = val;
        else
            cible.NouveauxAffiliesCNaPSCible = null;
    }
}
