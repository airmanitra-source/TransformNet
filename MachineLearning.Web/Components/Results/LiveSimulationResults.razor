@using Simulation.Module
@using Simulation.Module.Models
@using Simulation.Module.Config
@using Microsoft.Extensions.DependencyInjection

@if (Simulator.Result.Snapshots.Count > 0)
{
    var last = Simulator.Result.Snapshots[^1];
    var first = Simulator.Result.Snapshots[0];
    var recettesJourFirst = first.RecettesIR + first.RecettesIS + first.RecettesTVA + first.RecettesDouanieres;
    var recettesJourLast = last.RecettesIR + last.RecettesIS + last.RecettesTVA + last.RecettesDouanieres;
    var comparaison = _baselineLastSnapshot ?? first;
    var recettesJourComparaison = _baselineLastSnapshot != null
        ? _baselineLastSnapshot.RecettesIR + _baselineLastSnapshot.RecettesIS + _baselineLastSnapshot.RecettesTVA + _baselineLastSnapshot.RecettesDouanieres
        : recettesJourFirst;
    var libelleComparaison = _baselineLastSnapshot != null ? $"vs {_baselineScenarioName}" : "vs Jour 1";

    @* ═══════════════════════════════════════════════════════════════════
       TABLEAU DE BORD DÉCISIONNEL — KPI clés pour le policy-maker
       ═══════════════════════════════════════════════════════════════════ *@
    <div class="row mb-3">
        <div class="col-md-2">
            <div class="card text-center border-warning kpi-card">
                <div class="card-body py-2">
                    <small class="text-muted">📊 PIB/jour</small>
                    <h5 class="text-warning mb-0">@FormatMGA(last.PIBProxy)</h5>
                    <small class="@CssVariation(last.PIBProxy, comparaison.PIBProxy)">@FormatDelta(last.PIBProxy, comparaison.PIBProxy) (@libelleComparaison)</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center kpi-card @(recettesJourLast >= recettesJourComparaison ? "border-success" : "border-danger")">
                <div class="card-body py-2">
                    <small class="text-muted">🏛️ Recettes fisc./j</small>
                    <h5 class="@(recettesJourLast >= recettesJourComparaison ? "text-success" : "text-danger") mb-0">@FormatMGA(recettesJourLast)</h5>
                    <small class="@CssVariation(recettesJourLast, recettesJourComparaison)">@FormatDelta(recettesJourLast, recettesJourComparaison) (@libelleComparaison)</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center border-info kpi-card">
                <div class="card-body py-2">
                    <small class="text-muted">👷 Emploi</small>
                    <h5 class="text-info mb-0">@((last.TauxEmploi * 100).ToString("F1"))%</h5>
                    <small>@last.TotalEmployesEntreprises.ToString("N0") salariés</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center kpi-card @(last.TauxInflationEndogene > 0.10 ? "border-danger" : "border-primary")">
                <div class="card-body py-2">
                    <small class="text-muted">📈 Inflation</small>
                    <h5 class="@(last.TauxInflationEndogene > 0.10 ? "text-danger" : "text-primary") mb-0">@((last.TauxInflationEndogene * 100).ToString("F1"))%</h5>
                    <small>annualisée</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center kpi-card @(last.SoldeBudgetaire >= 0 ? "border-success" : "border-danger")">
                <div class="card-body py-2">
                    <small class="text-muted">💰 Solde budgétaire</small>
                    <h5 class="@(last.SoldeBudgetaire >= 0 ? "text-success" : "text-danger") mb-0">@FormatMGA(last.SoldeBudgetaire)</h5>
                    <small>cumulé</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center border-secondary kpi-card">
                <div class="card-body py-2">
                    <small class="text-muted">📉 Gini</small>
                    <h5 class="@(last.Gini > 0.5 ? "text-danger" : last.Gini > 0.4 ? "text-warning" : "text-success") mb-0">@last.Gini.ToString("F3")</h5>
                    <small class="@CssVariation(comparaison.Gini, last.Gini)">@FormatDelta(comparaison.Gini, last.Gini, true) (@libelleComparaison)</small>
                </div>
            </div>
        </div>
    </div>

    @if (_baselineLoading)
    {
        <div class="alert alert-info py-2 mb-3">
            <small>Calcul du scénario baseline pour le comparatif…</small>
        </div>
    }
    else if (_baselineLastSnapshot != null)
    {
        <div class="row mb-3">
            <div class="col-md-12">
                <div class="card border-success">
                    <div class="card-header bg-success text-white">
                        <strong>📊 Comparatif politique — Scénario courant vs @_baselineScenarioName</strong>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col">
                                <small class="text-muted">PIB/jour</small><br />
                                <strong class="@CssVariation(last.PIBProxy, comparaison.PIBProxy)">@FormatDelta(last.PIBProxy, comparaison.PIBProxy)</strong><br />
                                <small>@FormatMGA(comparaison.PIBProxy) → @FormatMGA(last.PIBProxy)</small>
                            </div>
                            <div class="col">
                                <small class="text-muted">Recettes fiscales/j</small><br />
                                <strong class="@CssVariation(recettesJourLast, recettesJourComparaison)">@FormatDelta(recettesJourLast, recettesJourComparaison)</strong><br />
                                <small>@FormatMGA(recettesJourComparaison) → @FormatMGA(recettesJourLast)</small>
                            </div>
                            <div class="col">
                                <small class="text-muted">Emploi total</small><br />
                                <strong class="@CssVariation(last.TotalEmployesEntreprises, comparaison.TotalEmployesEntreprises)">
                                    @FormatDeltaInt(last.TotalEmployesEntreprises, comparaison.TotalEmployesEntreprises)
                                </strong><br />
                                <small>@comparaison.TotalEmployesEntreprises.ToString("N0") → @last.TotalEmployesEntreprises.ToString("N0")</small>
                            </div>
                            <div class="col">
                                <small class="text-muted">Inégalités (Gini)</small><br />
                                <strong class="@CssVariation(comparaison.Gini, last.Gini)">@((last.Gini - comparaison.Gini).ToString("+0.000;-0.000;0.000"))</strong><br />
                                <small>@comparaison.Gini.ToString("F3") → @last.Gini.ToString("F3")</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_baselineError))
    {
        <div class="alert alert-warning py-2 mb-3">
            <small>@_baselineError</small>
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════════
       ÉVOLUTION INTERNE DU SCÉNARIO — Jour N vs Jour 1
       ═══════════════════════════════════════════════════════════════════ *@
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card border-dark">
                <div class="card-header bg-dark text-white">
                    <strong>🎯 Évolution interne du scénario — Jour final vs Jour 1</strong>
                </div>
                <div class="card-body">
                    <div class="alert alert-secondary py-2 mb-3">
                        <small>
                            Les pourcentages ci-dessous comparent le <strong>dernier jour</strong> au <strong>premier jour du même scénario</strong>.
                            Ils ne mesurent pas l'écart avec un scénario baseline.
                        </small>
                    </div>
                    <div class="row text-center">
                        <div class="col">
                            <small class="text-muted">PIB/jour</small><br />
                            <strong class="@CssVariation(last.PIBProxy, first.PIBProxy)">@FormatDelta(last.PIBProxy, first.PIBProxy)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Recettes fiscales/j</small><br />
                            <strong class="@CssVariation(recettesJourLast, recettesJourFirst)">@FormatDelta(recettesJourLast, recettesJourFirst)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Emploi total</small><br />
                            <strong class="@CssVariation(last.TotalEmployesEntreprises, first.TotalEmployesEntreprises)">
                                @FormatDeltaInt(last.TotalEmployesEntreprises, first.TotalEmployesEntreprises)
                            </strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Inflation</small><br />
                            <strong class="@CssVariation(first.TauxInflationEndogene, last.TauxInflationEndogene)">
                                @(((last.TauxInflationEndogene - first.TauxInflationEndogene) * 100).ToString("+0.0;-0.0;0.0")) pts
                            </strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Consommation/j</small><br />
                            <strong class="@CssVariation(last.ConsommationTotaleMenages, first.ConsommationTotaleMenages)">@FormatDelta(last.ConsommationTotaleMenages, first.ConsommationTotaleMenages)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Épargne ménages</small><br />
                            <strong class="@CssVariation(last.EpargneTotaleMenages, first.EpargneTotaleMenages)">@FormatDelta(last.EpargneTotaleMenages, first.EpargneTotaleMenages)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Gini</small><br />
                            <strong class="@CssVariation(first.Gini, last.Gini)">
                                @((last.Gini - first.Gini).ToString("+0.000;-0.000;0.000"))
                            </strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Balance comm.</small><br />
                            <strong class="@CssVariation(last.BalanceCommerciale, first.BalanceCommerciale)">@FormatDelta(last.BalanceCommerciale, first.BalanceCommerciale)</strong>
                        </div>
                    </div>
                    <hr class="my-2" />
                    <div class="row text-center">
                        <div class="col">
                            <small class="text-muted">Taux change MGA/USD</small><br />
                            <strong>@last.TauxChangeMGAParUSD.ToString("N0")</strong>
                            <small class="@CssVariation(first.TauxChangeMGAParUSD, last.TauxChangeMGAParUSD)">
                                (@FormatDelta(last.TauxChangeMGAParUSD, first.TauxChangeMGAParUSD))
                            </small>
                        </div>
                        <div class="col">
                            <small class="text-muted">Réserves BCM</small><br />
                            <strong>@((last.ReservesBCMUSD / 1_000_000).ToString("N0")) M USD</strong>
                            <small>(@last.ReservesMoisImports.ToString("F1") mois imports)</small>
                        </div>
                        <div class="col">
                            <small class="text-muted">Taux directeur</small><br />
                            <strong>@((last.TauxDirecteurEffectif * 100).ToString("F2"))%</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Part informel PIB</small><br />
                            <strong>@((last.PartInformelDansPIB * 100).ToString("F1"))%</strong>
                            <small class="@CssVariation(first.PartInformelDansPIB, last.PartInformelDansPIB)">
                                (@(((last.PartInformelDansPIB - first.PartInformelDansPIB) * 100).ToString("+0.0;-0.0;0.0")) pts)
                            </small>
                        </div>
                        <div class="col">
                            <small class="text-muted">Crédit économie</small><br />
                            <strong>@FormatMGA(last.EncoursCreditEconomie)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">NPL</small><br />
                            <strong class="@(last.RatioNPL > 0.10 ? "text-danger" : "")">@((last.RatioNPL * 100).ToString("F1"))%</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">SCB (liquidité)</small><br />
                            <strong>@FormatMGA(last.SoldeEnCompteBanques)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Dette publique</small><br />
                            <strong>@FormatMGA(last.DettePublique)</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════════════════════════════════
       RECETTES FISCALES DÉTAILLÉES (question clé pour la formalisation)
       ═══════════════════════════════════════════════════════════════════ *@
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <strong>🏛️ Recettes fiscales — Décomposition</strong>
                </div>
                <div class="card-body">
                    <div class="row text-center mb-2">
                        <div class="col">
                            <small class="text-muted">IR (salaires)</small><br />
                            <strong>@FormatMGA(last.RecettesIR)</strong>/j
                        </div>
                        <div class="col">
                            <small class="text-muted">IS (entreprises)</small><br />
                            <strong>@FormatMGA(last.RecettesIS)</strong>/j
                        </div>
                        <div class="col">
                            <small class="text-muted">TVA</small><br />
                            <strong>@FormatMGA(last.RecettesTVA)</strong>/j
                        </div>
                        <div class="col">
                            <small class="text-muted">Douanes</small><br />
                            <strong>@FormatMGA(last.RecettesDouanieres)</strong>/j
                        </div>
                    </div>
                    <hr class="my-1" />
                    <div class="row text-center">
                        <div class="col">
                            <small class="text-muted">Cumul</small><br />
                            <strong class="fs-5 text-success">@FormatMGA(last.RecettesFiscalesTotales)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Pression fiscale</small><br />
                            @{ var pressionFiscale = last.PIBProxy > 0 ? (last.RecettesIR + last.RecettesIS + last.RecettesTVA + last.RecettesDouanieres) / last.PIBProxy * 100 : 0; }
                            <strong class="fs-5">@pressionFiscale.ToString("F1")%</strong>
                            <br /><small class="text-muted">Cible FMI : 12-15%</small>
                        </div>
                        <div class="col">
                            <small class="text-muted">Assujetties TVA</small><br />
                            <strong class="fs-5">@last.NbEntreprisesAssujettiesTVA</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Ménages & Pouvoir d'achat ── *@
        <div class="col-md-6">
            <div class="card border-info">
                <div class="card-header bg-info text-white">
                    <strong>🏠 Ménages — Pouvoir d'achat & Inégalités</strong>
                </div>
                <div class="card-body">
                    <div class="row text-center mb-2">
                        <div class="col">
                            <small class="text-muted">Épargne moy.</small><br />
                            <strong>@FormatMGA(last.EpargneMoyenneMenages)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Consommation/j</small><br />
                            <strong>@FormatMGA(last.ConsommationTotaleMenages)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Privation alim.</small><br />
                            <strong class="@(last.FacteurReductionAlimentaireMoyen < 0.8 ? "text-danger" : "")">@((last.FacteurReductionAlimentaireMoyen * 100).ToString("F0"))%</strong>
                        </div>
                    </div>
                    <hr class="my-1" />
                    <small class="fw-bold">Épargne par quintile :</small>
                    <div class="d-flex justify-content-between mt-1">
                        <span class="badge bg-danger">Q1: @FormatMGA(last.EpargneQ1)</span>
                        <span class="badge bg-warning text-dark">Q2: @FormatMGA(last.EpargneQ2)</span>
                        <span class="badge bg-info">Q3: @FormatMGA(last.EpargneQ3)</span>
                        <span class="badge bg-primary">Q4: @FormatMGA(last.EpargneQ4)</span>
                        <span class="badge bg-success">Q5: @FormatMGA(last.EpargneQ5)</span>
                    </div>
                    <div class="d-flex justify-content-between mt-1">
                        <small>Gini: <strong>@last.Gini.ToString("F3")</strong></small>
                        <small>D9/D1: <strong>@last.RatioD9D1.ToString("F1")x</strong></small>
                        <small>Informels: <strong>@last.NbMenagesInformels.ToString("N0")</strong></small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════════════════════════════════
       PIB — 3 méthodes de validation croisée
       ═══════════════════════════════════════════════════════════════════ *@
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <strong>📊 PIB — 3 méthodes de calcul</strong>
                    <small class="ms-2">Écarts: Demande↔VA @CalculerEcart(last.PIBProxy, last.PIBParValeurAjoutee)% | VA↔Revenus @CalculerEcart(last.PIBParValeurAjoutee, last.PIBParRevenus)%</small>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted">Demande (C+I+G+X-M)</small><br />
                                <strong class="fs-5 text-primary">@FormatMGA(last.PIBProxy)</strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted">Valeur ajoutée (ΣVA)</small><br />
                                <strong class="fs-5 text-success">@FormatMGA(last.PIBParValeurAjoutee)</strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted">Revenus (W+EBE+T)</small><br />
                                <strong class="fs-5 text-warning">@FormatMGA(last.PIBParRevenus)</strong>
                            </div>
                        </div>
                    </div>
                    <hr class="my-2" />
                    <div class="row">
                        <div class="col-md-4">
                            <small>C: @FormatMGA(last.ConsommationTotaleMenages) | FBCF: @FormatMGA(last.FBCF) | G: @FormatMGA(last.DepensesPubliques - last.SubventionsJirama) | X-M: @FormatMGA(last.BalanceCommerciale)</small>
                        </div>
                        <div class="col-md-4">
                            <small>VA entr.: @FormatMGA(last.ChiffreAffairesTotalEntreprises - last.VentesB2BTotales) | Jirama: @FormatMGA(last.ValeurAjouteeJirama) | Admin: @FormatMGA(last.ValeurAjouteeAdminPublique)</small>
                        </div>
                        <div class="col-md-4">
                            <small>Salaires: @FormatMGA(last.ChargesSalarialesTotalesEntreprises) | EBE: @FormatMGA(last.ExcedentBrutExploitation) | T: @FormatMGA(last.RecettesTVA + last.RecettesDouanieres)</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Alerte cyclone ── *@
    @if (last.CycloneActif)
    {
        <div class="alert alert-danger d-flex align-items-center py-2 mb-3" role="alert">
            <span class="fs-3 me-2">🌀</span>
            <div>
                <strong>CYCLONE @last.CycloneNom</strong> — Jour @last.CycloneJourDans |
                Intensité: <strong>@((last.CycloneIntensite * 100).ToString("F0"))%</strong> |
                Productivité: <span class="text-danger fw-bold">@((last.CycloneFacteurProductivite * 100).ToString("F0"))%</span> |
                Prix alim.: <span class="text-warning fw-bold">×@(last.CycloneFacteurPrixAlimentaire.ToString("F2"))</span>
            </div>
        </div>
    }
    else if (last.CyclonePhaseReconstruction)
    {
        <div class="alert alert-warning d-flex align-items-center py-2 mb-3" role="alert">
            <span class="fs-3 me-2">🏗️</span>
            <div>
                <strong>RECONSTRUCTION POST-@last.CycloneNom</strong> — Jour @last.CycloneJourReconstruction |
                Ménages: <strong>@last.NbMenagesEnReconstructionCyclone.ToString("N0")</strong> |
                BTP: ×@(last.CycloneFacteurDemandeBTP.ToString("F2")) |
                Dépenses/j: <strong>@FormatMGA(last.DepensesReconstructionCycloneJour)</strong>
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════════
       COMMERCE EXTÉRIEUR & SECTEUR BANCAIRE
       ═══════════════════════════════════════════════════════════════════ *@
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card text-center border-primary kpi-card">
                <div class="card-body py-2">
                    <small class="text-muted">🚢 Imports CIF/j</small>
                    <h5 class="text-primary mb-0">@FormatMGA(last.ImportationsCIF)</h5>
                    <small>@last.NbImportateurs importateurs</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-success kpi-card">
                <div class="card-body py-2">
                    <small class="text-muted">📦 Exports FOB/j</small>
                    <h5 class="text-success mb-0">@FormatMGA(last.ExportationsFOB)</h5>
                    <small>@last.NbExportateurs exportateurs</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center kpi-card @(last.BalanceCommerciale >= 0 ? "border-success" : "border-danger")">
                <div class="card-body py-2">
                    <small class="text-muted">⚖️ Balance commerciale</small>
                    <h5 class="@(last.BalanceCommerciale >= 0 ? "text-success" : "text-danger") mb-0">@FormatMGA(last.BalanceCommerciale)</h5>
                    <small>Douanes: @FormatMGA(last.RecettesDouanieres)/j</small>
                </div>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════════════════════════════════
       SECTEUR BANCAIRE (SCB + Crédit + NPL)
       ═══════════════════════════════════════════════════════════════════ *@
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">
                    <strong>🏦 Secteur bancaire — Crédit, Liquidité & Agrégats monétaires</strong>
                </div>
                <div class="card-body">
                    <div class="row text-center mb-2">
                        <div class="col">
                            <small class="text-muted">M0 (base)</small><br />
                            <strong>@FormatMGA(last.BaseMonetaireM0)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">M3 (large)</small><br />
                            <strong>@FormatMGA(last.MasseMonetaireM3)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Multiplicateur</small><br />
                            <strong>×@(last.MultiplicateurMonetaire.ToString("F2"))</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Encours crédit</small><br />
                            <strong>@FormatMGA(last.EncoursCreditEconomie)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Crédit/j</small><br />
                            <strong>@FormatMGA(last.CreditsEntreprisesJour + last.CreditsMenagesJour)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">NPL</small><br />
                            <strong class="@(last.RatioNPL > 0.10 ? "text-danger fw-bold" : "")">@((last.RatioNPL * 100).ToString("F1"))%</strong>
                        </div>
                    </div>
                    <hr class="my-1" />
                    <div class="row text-center">
                        <div class="col">
                            <small class="text-muted">💧 SCB</small><br />
