@code {
    [Parameter]
    public ISimulationModule Simulator { get; set; } = default!;

    [Parameter]
    public ScenarioConfig Config { get; set; } = default!;

    [Inject]
    private IServiceScopeFactory ScopeFactory { get; set; } = default!;

    private DailySnapshot? _baselineLastSnapshot;
    private string _baselineScenarioName = "baseline";
    private string? _baselineError;
    private string? _baselineCacheKey;
    private bool _baselineLoading;

    protected override async Task OnParametersSetAsync()
    {
        if (!Simulator.Result.EstTerminee || Simulator.EnCours || Simulator.Result.Snapshots.Count == 0)
        {
            if (Simulator.EnCours)
            {
                _baselineLastSnapshot = null;
                _baselineError = null;
                _baselineCacheKey = null;
            }
            return;
        }

        var cacheKey = BuildBaselineCacheKey();
        if (_baselineLoading || _baselineCacheKey == cacheKey)
            return;

        _baselineLoading = true;
        _baselineError = null;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var baselineSimulator = scope.ServiceProvider.GetRequiredService<ISimulationModule>();

            var baselineConfig = await ChargerBaselineConfigAsync(baselineSimulator);
            baselineConfig.DureeJours = Config.DureeJours;
            baselineConfig.NombreMenages = Config.NombreMenages;
            baselineConfig.NombreEntreprises = Config.NombreEntreprises;

            // Synchronisation du calibrage structurel de l'utilisateur (propensions à consommer)
            baselineConfig.PropensionConsommation_Subsistance = Config.PropensionConsommation_Subsistance;
            baselineConfig.PropensionConsommation_InformelBas = Config.PropensionConsommation_InformelBas;
            baselineConfig.PropensionConsommation_FormelBas = Config.PropensionConsommation_FormelBas;
            baselineConfig.PropensionConsommation_FormelQualifie = Config.PropensionConsommation_FormelQualifie;
            baselineConfig.PropensionConsommation_Cadre = Config.PropensionConsommation_Cadre;

            // Synchronisation de la trésorerie initiale ajustée par l'utilisateur
            baselineConfig.TresorerieInitialeParSecteur = new Dictionary<Company.Module.Models.ESecteurActivite, double>(Config.TresorerieInitialeParSecteur);

            baselineSimulator.Initialiser(baselineConfig);
            baselineSimulator.SimulerNJoursSync(baselineConfig.DureeJours);

            _baselineLastSnapshot = baselineSimulator.Result.Snapshots.LastOrDefault();
            _baselineCacheKey = cacheKey;
        }
        catch (Exception ex)
        {
            _baselineLastSnapshot = null;
            _baselineError = $"Comparatif baseline indisponible : {ex.Message}";
            _baselineCacheKey = cacheKey;
        }
        finally
        {
            _baselineLoading = false;
        }
    }

    private string BuildBaselineCacheKey()
        => $"{Config.Name}|{Config.DureeJours}|{Config.NombreMenages}|{Config.NombreEntreprises}|{Simulator.Result.JoursSimules}";

    private async Task<ScenarioConfig> ChargerBaselineConfigAsync(ISimulationModule simulation)
    {
        try
        {
            var scenarios = await simulation.ListScenariosAsync();
            if (scenarios.FirstOrDefault(s => s.EstBase) is { } baseline)
            {
                _baselineScenarioName = baseline.Nom;
                return await simulation.ChargerScenarioAsync(baseline.Id);
            }
        }
        catch
        {
        }

        var config = ScenarioConfig.BaseMadagascar();
        _baselineScenarioName = config.Name;
        return config;
    }

    private List<DailySnapshot> GetSampledSnapshots()
    {
        var snapshots = Simulator.Result.Snapshots;
        if (snapshots.Count <= 30) return snapshots;

        int step = snapshots.Count / 30;
        var sampled = new List<DailySnapshot>();
        for (int i = 0; i < snapshots.Count; i += step)
        {
            sampled.Add(snapshots[i]);
        }
        if (sampled[^1] != snapshots[^1])
            sampled.Add(snapshots[^1]);
        return sampled;
    }

    private static string FormatMGA(double montant)
    {
        if (Math.Abs(montant) >= 1_000_000_000)
            return $"{montant / 1_000_000_000:F2} Mrd MGA";
        if (Math.Abs(montant) >= 1_000_000)
            return $"{montant / 1_000_000:F2} M MGA";
        if (Math.Abs(montant) >= 1_000)
            return $"{montant / 1_000:F1} k MGA";
        return $"{montant:F0} MGA";
    }

    private static string FormatMds(double montant)
    {
        if (Math.Abs(montant) >= 1_000_000_000_000)
            return $"{montant / 1_000_000_000_000:F1} Tds MGA";
        if (Math.Abs(montant) >= 1_000_000_000)
            return $"{montant / 1_000_000_000:F2} Mds MGA";
        if (Math.Abs(montant) >= 1_000_000)
            return $"{montant / 1_000_000:F1} M MGA";
        return $"{montant:F0} MGA";
    }

    private static string FormatTemps(int jours)
    {
        if (jours >= 365)
        {
            int ans = jours / 365;
            int moisRestants = (jours % 365) / 30;
            return moisRestants > 0 ? $"{ans} an(s) {moisRestants} mois" : $"{ans} an(s)";
        }
        if (jours >= 30)
            return $"{jours / 30} mois";
        return $"{jours} jour(s)";
    }

    private static string FormatPourcent(double finale, double initiale)
    {
        if (initiale == 0) return "N/A";
        double variation = (finale - initiale) / Math.Abs(initiale) * 100;
        string signe = variation >= 0 ? "+" : "";
        return $"{signe}{variation:F1}%";
    }

    private static string FormatDelta(double finale, double initiale)
    {
        if (initiale == 0) return "N/A";
        double variation = (finale - initiale) / Math.Abs(initiale) * 100;
        string signe = variation >= 0 ? "+" : "";
        return $"{signe}{variation:F1}%";
    }

    private static string FormatDelta(double finale, double initiale, bool inversed)
    {
        if (initiale == 0) return "N/A";
        double variation = (finale - initiale) / Math.Abs(initiale) * 100;
        string signe = variation >= 0 ? "+" : "";
        return $"{signe}{variation:F1}%";
    }

    private static string FormatDeltaInt(int finale, int initiale)
    {
        int diff = finale - initiale;
        string signe = diff >= 0 ? "+" : "";
        return $"{signe}{diff:N0}";
    }

    private static string CssVariation(double finale, double initiale)
    {
        if (finale > initiale) return "text-success";
        if (finale < initiale) return "text-danger";
        return "";
    }

    private static string CssVariation(int finale, int initiale)
    {
        if (finale > initiale) return "text-success";
        if (finale < initiale) return "text-danger";
        return "";
    }

    private static string CalculerEcart(double pib1, double pib2)
    {
        if (pib1 == 0 || pib2 == 0) return "N/A";
        double ecart = Math.Abs(pib1 - pib2) / ((pib1 + pib2) / 2.0) * 100.0;
        return ecart.ToString("F1");
    }

    private static string FormatSmallNumber(double val)
    {
        if (Math.Abs(val) < 0.001)
            return val.ToString("E2");
        if (Math.Abs(val) >= 1_000_000_000)
            return $"{val / 1_000_000_000:F2} Mds";
        if (Math.Abs(val) >= 1_000_000)
            return $"{val / 1_000_000:F1} M";
        return val.ToString("F4");
    }
}
