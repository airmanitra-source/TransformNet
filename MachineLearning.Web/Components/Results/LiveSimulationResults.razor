@using Simulation.Module
@using Simulation.Module.Models
@using Simulation.Module.Config

@if (Simulator.Result.Snapshots.Count > 0)
{
    var last = Simulator.Result.Snapshots[^1];
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card text-center border-info kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">💰 Épargne ménages</h6>
                    <h4 class="text-info">@FormatMGA(last.EpargneTotaleMenages)</h4>
                    <small>Moy: @FormatMGA(last.EpargneMoyenneMenages)</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-success kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">🏛️ Recettes fiscales</h6>
                    <h4 class="text-success">@FormatMGA(last.RecettesFiscalesTotales)</h4>
                    <small>IR: @FormatMGA(last.RecettesIR)/j</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-warning kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">📊 PIB par revenus</h6>
                    <h4 class="text-warning">@FormatMGA(last.PIBParRevenus)</h4>
                    <small>Salaires + Profits + Impôts</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-danger kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">📉 Dette publique</h6>
                    <h4 class="text-danger">@FormatMGA(last.DettePublique)</h4>
                    <small>Solde: @FormatMGA(last.SoldeBudgetaire)</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Secteur Bancaire et M3 -->
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card text-center border-primary kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">🏦 Masse Monétaire M3</h6>
                    <h4 class="text-primary">@FormatMGA(last.MasseMonetaireM3)</h4>
                    <small>Base crédit monétaire de la simulation</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-info kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">💼 Dépôts Bancaires</h6>
                    <h4 class="text-info">@FormatMGA(last.TotalDepotsBancaires)</h4>
                    <small>Ménages + Entreprises</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-success kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">💳 Crédits Accordés (cumul)</h6>
                    <h4 class="text-success">@FormatMGA(last.TotalCreditsAccordes)</h4>
                    <small>Nouvelle monnaie créée</small>
                </div>
            </div>
        </div>
    </div>

    <!-- 3 estimations du PIB pour validation croisée -->
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <strong>📊 PIB - Validation croisée des 3 méthodes de calcul</strong>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted">1️⃣ PIB par la demande</small><br />
                                <strong class="fs-4 text-primary">@FormatMGA(last.PIBProxy)</strong>
                                <br /><small class="text-muted">C + I(FBCF+ΔS) + G + (X - M)</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted">2️⃣ PIB par la valeur ajoutée</small><br />
                                <strong class="fs-4 text-success">@FormatMGA(last.PIBParValeurAjoutee)</strong>
                                <br /><small class="text-muted">Σ(VA entreprises + JIRAMA + Admin + Loyers)</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted">3️⃣ PIB par les revenus</small><br />
                                <strong class="fs-4 text-warning">@FormatMGA(last.PIBParRevenus)</strong>
                                <br /><small class="text-muted">Salaires + EBE + Impôts prod.</small>
                            </div>
                        </div>
                    </div>
                    <hr class="my-2" />
                    <div class="text-center">
                        <small class="text-muted">
                            💡 En théorie, les 3 méthodes devraient converger vers la même valeur.
                            Écarts: 
                            <strong>Demande ↔ VA: @CalculerEcart(last.PIBProxy, last.PIBParValeurAjoutee)%</strong> | 
                            <strong>VA ↔ Revenus: @CalculerEcart(last.PIBParValeurAjoutee, last.PIBParRevenus)%</strong>
                        </small>
                    </div>
                    <hr class="my-2" />
                    <div class="row">
                        <div class="col-md-4">
                            <small class="text-muted"><strong>Demande :</strong></small><br />
                            <small>C ménages : @FormatMGA(last.ConsommationTotaleMenages)</small><br />
                            <small>FBCF : @FormatMGA(last.FBCF)</small><br />
                            <small>ΔStocks : @FormatMGA(last.VariationStocksImportateurs)</small><br />
                            <small>G (conso. État) : @FormatMGA(last.DepensesPubliques - last.SubventionsJirama)</small><br />
                            <small>X - M : @FormatMGA(last.BalanceCommerciale)</small><br />
                            <small>Loyers imputés : @FormatMGA(last.LoyersImputesTotaux)</small>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted"><strong>Valeur ajoutée :</strong></small><br />
                            <small>VA entreprises : @FormatMGA(last.ChiffreAffairesTotalEntreprises - last.VentesB2BTotales)</small><br />
                            <small>VA JIRAMA : @FormatMGA(last.ValeurAjouteeJirama)</small><br />
                            <small>VA Admin publique : @FormatMGA(last.ValeurAjouteeAdminPublique)</small><br />
                            <small>Loyers imputés : @FormatMGA(last.LoyersImputesTotaux)</small>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted"><strong>Revenus :</strong></small><br />
                            <small>Salaires entreprises : @FormatMGA(last.ChargesSalarialesTotalesEntreprises)</small><br />
                            <small>CNaPS patronales : @FormatMGA(last.CotisationsCNaPSPatronalesTotales)</small><br />
                            <small>Sal. fonctionnaires : @FormatMGA(last.SalairesFonctionnaires)</small><br />
                            <small>EBE (profits) : @FormatMGA(last.ExcedentBrutExploitation)</small><br />
                            <small>Impôts production : @FormatMGA(last.RecettesTVA + last.RecettesDouanieres)</small><br />
                            <small>Loyers imputés : @FormatMGA(last.LoyersImputesTotaux)</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Commerce extérieur -->
    <div class="row mb-3">

    @* ── Alerte cyclone en temps réel ── *@
    @if (last.CycloneActif)
    {
        <div class="col-md-12 mb-2">
            <div class="alert alert-danger d-flex align-items-center py-2 mb-0" role="alert">
                <span class="fs-3 me-2">🌀</span>
                <div>
                    <strong>CYCLONE @last.CycloneNom EN COURS</strong> — Jour @last.CycloneJourDans |
                    Intensité : <strong>@((last.CycloneIntensite * 100).ToString("F0"))%</strong> |
                    Productivité : <span class="text-danger fw-bold">@((last.CycloneFacteurProductivite * 100).ToString("F0"))%</span> |
                    Prix alimentaires : <span class="text-warning fw-bold">×@(last.CycloneFacteurPrixAlimentaire.ToString("F2"))</span>
                </div>
            </div>
        </div>
    }
    else if (last.CyclonePhaseReconstruction)
    {
        <div class="col-md-12 mb-2">
            <div class="alert alert-warning d-flex align-items-center py-2 mb-0" role="alert">
                <span class="fs-3 me-2">🏗️</span>
                <div>
                    <strong>RECONSTRUCTION POST-@last.CycloneNom</strong> — Jour @last.CycloneJourReconstruction |
                    Ménages en reconstruction : <strong>@last.NbMenagesEnReconstructionCyclone.ToString("N0")</strong> |
                    Boost BTP : <span class="text-success fw-bold">×@(last.CycloneFacteurDemandeBTP.ToString("F2"))</span> |
                    Boost quincaillerie : <span class="text-success fw-bold">×@(last.CycloneFacteurDemandeQuincaillerie.ToString("F2"))</span>
                    @if (last.DepensesReconstructionCycloneJour > 0)
                    {
                        <span>| Dépenses reconstruction/j : <strong>@FormatMGA(last.DepensesReconstructionCycloneJour)</strong>
                            <span class="text-muted">(BTP: @FormatMGA(last.DepensesReconstructionBTPJour) | Quincaillerie: @FormatMGA(last.DepensesReconstructionQuincaillerieJour) | Transport: @FormatMGA(last.DepensesReconstructionTransportJour))</span>
                        </span>
                    }
                </div>
            </div>
        </div>
    }
    @* ── Fin alerte cyclone ── *@

        <div class="col-md-4">
            <div class="card text-center border-primary kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">🚢 Imports CIF/j</h6>
                    <h4 class="text-primary">@FormatMGA(last.ImportationsCIF)</h4>
                    <small>@last.NbImportateurs importateurs</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-success kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">📦 Exports FOB/j</h6>
                    <h4 class="text-success">@FormatMGA(last.ExportationsFOB)</h4>
                    <small>@last.NbExportateurs exportateurs</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center kpi-card @(last.BalanceCommerciale >= 0 ? "border-success" : "border-danger")">
                <div class="card-body">
                    <h6 class="card-title text-muted">⚖️ Balance commerciale</h6>
                    <h4 class="@(last.BalanceCommerciale >= 0 ? "text-success" : "text-danger")">@FormatMGA(last.BalanceCommerciale)</h4>
                    <small>Douanes: @FormatMGA(last.RecettesDouanieres)/j</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Riz & JIRAMA -->
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card text-center border-warning kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">🍚 Dépenses riz/j</h6>
                    <h4 class="text-warning">@FormatMGA(last.DepensesRizTotales)</h4>
                    <small>Tous ménages confondus</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-info kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">💧⚡ JIRAMA recettes/j</h6>
                    <h4 class="text-info">@FormatMGA(last.RecettesTotalesJirama)</h4>
                    <small>Eau: @FormatMGA(last.RecettesEauJirama) | Élec: @FormatMGA(last.RecettesElectriciteJirama)</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-secondary kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">⚡ Conso. élec. ménages</h6>
                    <h4 class="text-secondary">@last.ConsommationMenagesKWh.ToString("N0") KWh</h4>
                    <small>Prod. estimée: @last.ProductionElecKWh.ToString("N0") KWh</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-primary kpi-card">
                <div class="card-body">
                    <h6 class="card-title text-muted">🔌 Abonnés & facture</h6>
                    <h4 class="text-primary">@FormatMGA(last.FactureElecMoyenneParMenage)/j</h4>
                    <small>💧 @last.NbAbonnesEau.ToString("N0") | ⚡ @last.NbAbonnesElectricite.ToString("N0") abonnés</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Distribution salariale & inégalités -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card border-purple">
                <div class="card-header bg-dark text-white">
                    📊 Distribution salariale initiale (log-normale)
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col">
                            <small class="text-muted">Médiane</small><br />
                            <strong>@FormatMGA(Simulator.StatsInitiales.Mediane)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Moyenne</small><br />
                            <strong>@FormatMGA(Simulator.StatsInitiales.Moyenne)</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">Gini initial</small><br />
                            <strong>@Simulator.StatsInitiales.Gini.ToString("F3")</strong>
                        </div>
                        <div class="col">
                            <small class="text-muted">D9/D1</small><br />
                            <strong>@Simulator.StatsInitiales.RatioD9D1.ToString("F1")</strong>
                        </div>
                    </div>
                    <hr class="my-2" />
                    <small class="fw-bold">Quintiles (salaire mensuel) :</small>
                    <div class="d-flex justify-content-between mt-1">
                        <span class="badge bg-danger">Q1: @FormatMGA(Simulator.StatsInitiales.Q1Moyenne)</span>
                        <span class="badge bg-warning text-dark">Q2: @FormatMGA(Simulator.StatsInitiales.Q2Moyenne)</span>
                        <span class="badge bg-info">Q3: @FormatMGA(Simulator.StatsInitiales.Q3Moyenne)</span>
                        <span class="badge bg-primary">Q4: @FormatMGA(Simulator.StatsInitiales.Q4Moyenne)</span>
                        <span class="badge bg-success">Q5: @FormatMGA(Simulator.StatsInitiales.Q5Moyenne)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    📈 Inégalités en temps réel
                </div>
                <div class="card-body">
                    <div class="row text-center mb-2">
                        <div class="col">
                            <small class="text-muted">Gini (épargne)</small><br />
                            <h5 class="@(last.Gini > 0.5 ? "text-danger" : last.Gini > 0.4 ? "text-warning" : "text-success")">
                                @last.Gini.ToString("F3")
                            </h5>
                        </div>
                        <div class="col">
                            <small class="text-muted">Ratio D9/D1</small><br />
                            <h5>@last.RatioD9D1.ToString("F1")x</h5>
                        </div>
                    </div>
                    <small class="fw-bold">Épargne moy. par quintile :</small>
                    <div class="d-flex justify-content-between mt-1">
                        <span class="badge bg-danger">Q1: @FormatMGA(last.EpargneQ1)</span>
                        <span class="badge bg-warning text-dark">Q2: @FormatMGA(last.EpargneQ2)</span>
                        <span class="badge bg-info">Q3: @FormatMGA(last.EpargneQ3)</span>
                        <span class="badge bg-primary">Q4: @FormatMGA(last.EpargneQ4)</span>
                        <span class="badge bg-success">Q5: @FormatMGA(last.EpargneQ5)</span>
                    </div>
                    <hr class="my-2" />
                    <small class="fw-bold">Répartition des classes :</small>
                    <div class="d-flex justify-content-between mt-1">
                        <span class="badge bg-secondary">Subsist. @last.NbSubsistance</span>
                        <span class="badge bg-secondary">Inf.bas @last.NbInformelBas</span>
                        <span class="badge bg-secondary">Form.bas @last.NbFormelBas</span>
                        <span class="badge bg-secondary">Qualifié @last.NbFormelQualifie</span>
                        <span class="badge bg-secondary">Cadre @last.NbCadre</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Validation cohérence CA par secteur -->
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">
                    ✅ Validation : Cohérence CA par employé et secteur
                </div>
                <div class="card-body">
                    <div class="row text-center mb-3">
                        <div class="col-md-3">
                            <small class="text-muted">Entreprises assujetties TVA</small><br />
                            <strong class="fs-5 text-success">@last.NbEntreprisesAssujettiesTVA</strong>
                            <br /><small class="text-muted">(CA > 400M MGA/an)</small>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Cohérence globale</small><br />
                            <strong class="fs-5 @(last.PourcentageCoherenceCA >= 70 ? "text-success" : "text-warning")">
                                @last.PourcentageCoherenceCA.ToString("F1")%
                            </strong>
                            <br /><small class="text-muted">(ratio 0.5-2.0)</small>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">CA moyen/employé/jour</small><br />
                            <strong class="fs-5">@FormatMGA(last.CAMoyenParEmploye)</strong>
                        </div>
                    </div>
                    <hr />
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="p-2 border rounded">
                                <small class="fw-bold text-primary">🧵 Textile Export</small><br />
                                <strong>@FormatMGA(last.CAMoyenParEmployeTextile)</strong>/j
                                <br /><small class="text-muted">Attendu: 27-55k MGA</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-2 border rounded">
                                <small class="fw-bold text-success">🏪 Commerce/Services</small><br />
                                <strong>@FormatMGA(last.CAMoyenParEmployeCommerce)</strong>/j
                                <br /><small class="text-muted">Attendu: 73-110k MGA</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-2 border rounded">
                                <small class="fw-bold text-warning">⛏️ Secteur Minier</small><br />
                                <strong>@FormatMGA(last.CAMoyenParEmployeMinier)</strong>/j
                                <br /><small class="text-muted">Attendu: 200-274k MGA</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Secteur Informel — Dualité structurelle -->
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card border-secondary">
                <div class="card-header bg-dark text-white">
                    <strong>🏪 Secteur Informel — Dualité structurelle (INSTAT ENEMPSI)</strong>
                </div>
                <div class="card-body">
                    <!-- KPI principaux -->
                    <div class="row text-center mb-3">
                        <div class="col-md-3">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted">Part informel dans PIB</small><br />
                                <strong class="fs-4 @(last.PartInformelDansPIB > 0.35 ? "text-warning" : "text-success")">
                                    @((last.PartInformelDansPIB * 100).ToString("F1"))%
                                </strong>
                                <br /><small class="text-muted">Cible INSTAT : 40-55%</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted">Taux emploi informel</small><br />
                                <strong class="fs-4 text-warning">
                                    @((last.TauxEmploiInformel * 100).ToString("F1"))%
                                </strong>
                                <br /><small class="text-muted">Cible INSTAT : ~85%</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted">Entreprises informelles</small><br />
                                <strong class="fs-4 text-secondary">
                                    @last.NbEntreprisesInformelles.ToString("N0")
                                </strong>
                                <br /><small class="text-muted">sur total entreprises</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted">Ménages informels</small><br />
                                <strong class="fs-4 text-secondary">
                                    @last.NbMenagesInformels.ToString("N0")
                                </strong>
                                <br /><small class="text-muted">dont @last.NbMenagesAutoEmploi.ToString("N0") auto-employés</small>
                            </div>
                        </div>
                    </div>

                    <!-- Comparaison formel vs informel -->
                    <hr class="my-2" />
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-center text-muted mb-2">🏪 Secteur Informel</h6>
                            <table class="table table-sm table-bordered mb-0">
                                <tbody>
                                    <tr>
                                        <td>CA / jour</td>
                                        <td class="text-end"><strong>@FormatMGA(last.ChiffreAffairesInformel)</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Valeur ajoutée / jour</td>
                                        <td class="text-end"><strong>@FormatMGA(last.ValeurAjouteeInformel)</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Productivité moy. / employé</td>
                                        <td class="text-end"><strong>@FormatMGA(last.ProductiviteMoyenneInformel)</strong>/j</td>
                                    </tr>
                                    <tr>
                                        <td>Trésorerie moyenne</td>
                                        <td class="text-end"><strong>@FormatMGA(last.TresorerieMoyenneInformel)</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Revenu moy. ménage / jour</td>
                                        <td class="text-end"><strong>@FormatMGA(last.RevenuMoyenMenagesInformels)</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Emplois</td>
                                        <td class="text-end"><strong>@last.NbEmployesSecteurInformel.ToString("N0")</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Revenus annexes / jour</td>
                                        <td class="text-end"><strong>@FormatMGA(last.RevenusInformelsAnnexesJour)</strong></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-center text-muted mb-2">🏢 Secteur Formel</h6>
                            <table class="table table-sm table-bordered mb-0">
                                <tbody>
                                    <tr>
                                        <td>CA / jour</td>
                                        <td class="text-end"><strong>@FormatMGA(last.ChiffreAffairesFormel)</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Valeur ajoutée / jour</td>
                                        <td class="text-end"><strong>@FormatMGA(last.ValeurAjouteeFormel)</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Productivité moy. / employé</td>
